---
import BaseLayout from '@/layouts/BaseLayout.astro'; import FAQ from '@/components/FAQ.astro'; import { faqs } from '@/data/faqs';
const jsonLd=[{'@context':'https://schema.org','@type':'FAQPage',mainEntity:faqs.map(f=>({'@type':'Question',name:f.question,acceptedAnswer:{'@type':'Answer',text:f.answer}}))}];
---
<BaseLayout title="Preguntas frecuentes | Flopitec" description="Condiciones, garantías y dudas habituales del servicio técnico Flopitec." path="/preguntas-frecuentes/" jsonLd={jsonLd}><section class="section"><div class="container max-w-3xl"><p class="eyebrow">FAQ</p><h1 class="mt-3 text-4xl font-black">Preguntas frecuentes</h1><div class="mt-8"><FAQ items={faqs}/></div></div></section></BaseLayout>
