---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTASection from '@/components/CTASection.astro';
import QrGenerator from '@/components/tools/QrGenerator.astro';
---
<BaseLayout title="Generador de códigos QR online | Flopitec" description="Crea códigos QR para enlaces, textos, redes Wi-Fi, teléfonos, correos y WhatsApp directamente en tu navegador y descárgalos en PNG o SVG." path="/herramientas/generador-codigos-qr/">
  <Breadcrumbs items={[{ label: 'Herramientas', href: '/herramientas/' }]} />
  <section class="section"><div class="container"><p class="eyebrow">Herramientas</p><h1 class="mt-3 text-4xl font-black">Generador de códigos QR</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Crea un código QR para compartir un enlace, un texto, una red Wi-Fi u otros datos. La generación se realiza directamente en tu navegador y la información no se envía a nuestros servidores.</p><p class="mt-6 rounded-2xl border border-[var(--accent)]/60 bg-orange-500/10 p-4 font-bold">Comprueba siempre el contenido antes de compartir el código. Un código QR de una red Wi-Fi contiene los datos necesarios para conectarse y cualquier persona que pueda escanearlo podría acceder a esa información.</p><div class="mt-8"><QrGenerator /></div></div></section>
  <section class="section pt-0"><div class="container grid gap-5 md:grid-cols-2"><article class="card p-6"><h2 class="text-2xl font-black">¿Cómo se genera el código?</h2><p class="mt-3 text-[var(--muted)]">La herramienta convierte los datos introducidos en una matriz QR dentro de tu navegador. Después puedes descargar el resultado como una imagen PNG o como un archivo SVG.</p></article><article class="card p-6"><h2 class="text-2xl font-black">Antes de compartirlo</h2><p class="mt-3 text-[var(--muted)]">Escanea el código con otro dispositivo para comprobar que abre el contenido correcto. Utiliza un fondo claro, conserva un margen alrededor del código y evita modificar la imagen después de descargarla.</p></article><a class="font-bold text-flopi-orange" href="/herramientas/">← Volver a Herramientas</a></div></section>
  <CTASection title="¿Necesitas ayuda para preparar un código QR?" text="Escríbenos si necesitas orientación para crear o utilizar un código QR." />
</BaseLayout>
