---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTASection from '@/components/CTASection.astro';
import ImageConverter from '@/components/tools/ImageConverter.astro';
---

<BaseLayout
  title="Convertidor de imágenes JPG, PNG y WebP | Flopitec"
  description="Convierte imágenes JPG, PNG y WebP, cambia sus dimensiones y ajusta su calidad directamente en tu navegador sin subir los archivos a un servidor."
  path="/herramientas/convertidor-imagenes/"
>
  <Breadcrumbs items={[{ label: 'Herramientas', href: '/herramientas/' }]} />

  <section class="section">
    <div class="container">
      <p class="eyebrow">Herramientas</p>
      <h1 class="mt-3 text-4xl font-black">Convertidor de imágenes JPG, PNG y WebP</h1>
      <p class="mt-4 max-w-3xl text-[var(--muted)]">
        Selecciona una imagen, elige el formato y ajusta sus dimensiones. La conversión se realiza directamente en tu navegador y el archivo no se envía a nuestros servidores.
      </p>
      <p class="mt-6 rounded-2xl border border-[var(--line)] bg-[var(--soft)]/80 p-4 font-bold">
        En esta primera versión se procesa una imagen cada vez.
      </p>

      <div class="mt-8">
        <ImageConverter />
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container grid gap-5 md:grid-cols-2">
      <article class="card p-6 md:p-8">
        <h2 class="text-2xl font-black">¿Cómo funciona?</h2>
        <p class="mt-3 text-[var(--muted)]">
          El navegador abre la imagen seleccionada, genera una nueva versión con las opciones que elijas y prepara el archivo para descargarlo. El proceso se realiza localmente en tu dispositivo.
        </p>
      </article>
      <article class="card p-6 md:p-8">
        <h2 class="text-2xl font-black">Formatos disponibles</h2>
        <p class="mt-3 text-[var(--muted)]">
          Puedes utilizar imágenes JPG, PNG y WebP. JPG suele ser adecuado para fotografías, PNG permite conservar transparencias y WebP puede reducir el tamaño manteniendo una calidad visual adecuada.
        </p>
      </article>
    </div>
  </section>

  <CTASection title="¿Tienes problemas con una imagen?" text="Escríbenos si no puedes abrir, convertir o preparar un archivo y necesitas orientación." />
</BaseLayout>
