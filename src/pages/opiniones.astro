---
import BaseLayout from '@/layouts/BaseLayout.astro'; import CTASection from '@/components/CTASection.astro';
---
<BaseLayout title="Opiniones | Flopitec" description="Página de opiniones preparada para una fase posterior. En V1 no se muestran valoraciones ni reseñas." path="/opiniones/"><section class="section"><div class="container max-w-3xl"><p class="eyebrow">Opiniones</p><h1 class="mt-3 text-4xl font-black">Opiniones pendientes de revisión</h1><p class="mt-4 text-[var(--muted)]">En esta V1 no se muestran valoraciones, puntuaciones ni textos de clientes. Esta sección queda preparada para una fase posterior, cuando el contenido esté validado.</p><p class="mt-3 text-[var(--muted)]">Mientras tanto, la vía recomendada es contactar directamente con el taller para resolver dudas concretas.</p></div></section><CTASection title="¿Necesitas orientación antes de venir?" /></BaseLayout>
