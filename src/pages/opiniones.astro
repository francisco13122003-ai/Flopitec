---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { business } from '@/data/business';
---
<BaseLayout title="Opiniones | Flopitec" description="Página de opiniones preparada para una fase posterior. En V1 no se muestran valoraciones ni reseñas." path="/opiniones/"><section class="section"><div class="container max-w-3xl"><p class="eyebrow">Opiniones</p><h1 class="mt-3 text-4xl font-black">Opiniones de clientes</h1><p class="mt-4 text-[var(--muted)]">En esta V1 todavía no se muestran valoraciones ni textos de opiniones. Próximamente se podrá consultar información revisada de forma prudente.</p><a class="btn btn-primary mt-6" href={business.reviewUrl}>Dejar una reseña</a></div></section></BaseLayout>
