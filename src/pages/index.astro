---
import BaseLayout from '@/layouts/BaseLayout.astro'; import Hero from '@/components/Hero.astro'; import ServiceCard from '@/components/ServiceCard.astro'; import ContactBlock from '@/components/ContactBlock.astro'; import CTASection from '@/components/CTASection.astro';
import { featuredServices } from '@/data/services';
---
<BaseLayout path="/" title="Servicio técnico informático en La Zubia y Granada | Flopitec" description="Reparación de ordenadores, portátiles, móviles y consolas en La Zubia. Diagnóstico claro, trato cercano y soluciones realistas."><Hero title="Servicio técnico informático en La Zubia y Granada" subtitle="Reparamos, configuramos y asesoramos sin vender de más. Te explicamos qué le ocurre a tu equipo y qué opciones reales tienes."/><section class="section"><div class="container"><p class="eyebrow">Servicios destacados</p><h2 class="mt-3 text-3xl font-black">Informática, reparación y segunda vida</h2><div class="services-grid mt-8">{featuredServices.map(service=><ServiceCard service={service}/>)}</div></div></section><section class="section bg-[var(--soft)] philosophy-section"><div class="container"><h2 class="text-3xl font-black philosophy-heading">Filosofía Flopitec</h2><div class="philosophy-grid"><article class="card p-5 philosophy-card"><h3 class="font-black">Explicaciones claras</h3><p class="mt-2 text-[var(--muted)]">Te contamos qué le ocurre al equipo, qué hemos hecho y por qué, con palabras sencillas.</p></article><article class="card p-5 philosophy-card"><h3 class="font-black">Reparar solo si compensa</h3><p class="mt-2 text-[var(--muted)]">Valoramos el coste de la reparación según el valor, la antigüedad y el uso del aparato.</p></article><article class="card p-5 philosophy-card"><h3 class="font-black">Solo lo que necesitas</h3><p class="mt-2 text-[var(--muted)]">Recomendamos la solución más adecuada para tu caso, sin cambios innecesarios ni gastos de más.</p></article><article class="card p-5 philosophy-card"><h3 class="font-black">Presupuesto con transparencia</h3><p class="mt-2 text-[var(--muted)]">Siempre que el diagnóstico lo permite, te informamos del coste antes de reparar. Algunas averías requieren pruebas previas para poder confirmarlas.</p></article></div></div></section><section class="section"><div class="container grid gap-6 md:grid-cols-2"><div><p class="eyebrow">Sostenibilidad</p><h2 class="mt-3 text-3xl font-black">Reparar antes que tirar</h2><p class="mt-4 text-[var(--muted)]">Apostamos por reutilización, equipos de segunda mano, reciclaje electrónico y pequeñas decisiones que alargan la vida útil de ordenadores, portátiles, móviles y consolas.</p></div><div class="placeholder" role="img" aria-label="Imagen real pendiente sobre segunda vida y reciclaje electrónico"></div></div></section><section class="section bg-[var(--soft)]"><div class="container"><h2 class="text-3xl font-black">Nuestro taller</h2><p class="mt-3 text-[var(--muted)]">Conoce nuestra fachada, mostrador y zona técnica: espacios reales donde atendemos, asesoramos y reparamos tus equipos con cercanía.</p><div class="mt-6 grid-auto workshop-gallery"><img src="/images/flopitec-fachada.webp" alt="Zona del taller de Flopitec junto al área de tienda" width="720" height="480" loading="lazy" decoding="async"/><img src="/images/flopitec-mostrador.webp" alt="Área de trabajo y mostrador de Flopitec" width="720" height="480" loading="lazy" decoding="async"/><img src="/images/flopitec-taller-reparacion.webp" alt="Zona técnica de reparación del taller de Flopitec" width="720" height="480" loading="lazy" decoding="async"/></div></div></section><section class="section"><div class="container"><h2 class="text-3xl font-black">Servicio local cerca de ti</h2><p class="mt-3 text-[var(--muted)]">Atendemos en La Zubia y Granada, con cercanía para Cájar, Ogíjares, Armilla, Huétor Vega, Monachil, alrededores y anillo metropolitano de Granada.</p></div></section><ContactBlock/><CTASection/></BaseLayout>
