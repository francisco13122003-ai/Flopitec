---
import BaseLayout from '@/layouts/BaseLayout.astro'; import Hero from '@/components/Hero.astro'; import ServiceCard from '@/components/ServiceCard.astro'; import ContactBlock from '@/components/ContactBlock.astro'; import CTASection from '@/components/CTASection.astro'; import ReviewBlock from '@/components/ReviewBlock.astro';
import { featuredServices } from '@/data/services';
---
<BaseLayout path="/" title="Servicio técnico informático en La Zubia y Granada | Flopitec" description="Reparación de ordenadores, portátiles, móviles y consolas en La Zubia. Diagnóstico claro, trato cercano y soluciones realistas."><Hero title="Servicio técnico informático en La Zubia y Granada" subtitle="Reparamos, configuramos y asesoramos sin vender de más. Te explicamos qué le ocurre a tu equipo y qué opciones reales tienes."/><section class="section"><div class="container"><p class="eyebrow">Servicios destacados</p><h2 class="mt-3 text-3xl font-black">Informática, reparación y segunda vida</h2><div class="services-grid mt-8">{featuredServices.map(service=><ServiceCard service={service}/>)}</div></div></section><section class="section bg-[var(--soft)]"><div class="container grid gap-4 md:grid-cols-4"><div><h2 class="text-3xl font-black">Filosofía Flopitec</h2></div>{['Diagnóstico claro antes de reparar','Explicaciones sencillas','No vender de más','Reparar cuando compensa'].map(text=><article class="card p-5"><h3 class="font-black">{text}</h3><p class="mt-2 text-[var(--muted)]">Buscamos una solución realista según valor del equipo, coste y uso.</p></article>)}</div></section><section class="section"><div class="container grid gap-6 md:grid-cols-2"><div><p class="eyebrow">Sostenibilidad</p><h2 class="mt-3 text-3xl font-black">Reparar antes que tirar</h2><p class="mt-4 text-[var(--muted)]">Apostamos por reutilización, equipos de segunda mano, reciclaje electrónico y pequeñas decisiones que alargan la vida útil de ordenadores, portátiles, móviles y consolas.</p></div><div class="placeholder" role="img" aria-label="Imagen real pendiente sobre segunda vida y reciclaje electrónico"></div></div></section><section class="section bg-[var(--soft)]"><div class="container"><h2 class="text-3xl font-black">Nuestro taller</h2><p class="mt-3 text-[var(--muted)]">Los espacios visuales quedan preparados para fotos reales de fachada, mostrador y zona técnica cuando estén disponibles.</p><div class="mt-6 grid-auto"><div class="placeholder"></div><div class="placeholder"></div><div class="placeholder"></div></div></div></section><section class="section"><div class="container"><h2 class="text-3xl font-black">Servicio local cerca de ti</h2><p class="mt-3 text-[var(--muted)]">Atendemos en La Zubia y Granada, con cercanía para Cájar, Ogíjares, Armilla, Huétor Vega, Monachil, alrededores y anillo metropolitano de Granada.</p></div></section><ReviewBlock/><ContactBlock/><CTASection/></BaseLayout>
