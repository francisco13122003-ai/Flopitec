---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTASection from '@/components/CTASection.astro';
import { servicePages } from '@/data/services';

export function getStaticPaths() {
  return servicePages.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service } = Astro.props;
const path = `/servicios/${service.slug}/`;
const title = `${service.title} | Servicios Flopitec`;
const description = `${service.phrase} Servicios de ${service.title.toLowerCase()} en Flopitec Servicios Informáticos.`;
---
<BaseLayout title={title} description={description} path={path}>
  <Breadcrumbs items={[{ label: 'Servicios', href: '/servicios/' }, { label: service.title, href: path }]} />
  <article class="section">
    <div class="container">
      <p class="eyebrow">Servicios</p>
      <h1 class="mt-3 text-4xl font-black">{service.title}</h1>
      <p class="mt-5 max-w-3xl text-lg text-[var(--muted)]">{service.phrase}</p>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {service.services.map((item) => (
          <section class="card p-5">
            <h2 class="text-xl font-black">{item.title}</h2>
            <p class="mt-2 text-[var(--muted)]">{item.description}</p>
          </section>
        ))}
      </div>
    </div>
  </article>
  <CTASection title={`¿Necesitas ayuda con ${service.title.toLowerCase()}?`} text="Escríbenos por WhatsApp o revisa las vías de contacto para contarnos qué necesitas." />
</BaseLayout>
