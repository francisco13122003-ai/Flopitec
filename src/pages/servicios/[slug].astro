---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTASection from '@/components/CTASection.astro';
import { servicePages, getServiceBySlug } from '@/data/services';
import { getCollection } from 'astro:content';
import { isPublicBlogPost, toBlogCardPost } from '@/lib/blog';
import { business } from '@/data/business';
import { site } from '@/data/site';
export function getStaticPaths(){return servicePages.map(service=>({params:{slug:service.slug}}));}
const service = getServiceBySlug(Astro.params.slug!);
if (!service) return Astro.redirect('/servicios/');
const path = `/servicios/${service.slug}/`;
const buildTime = new Date();
const publicBlogPosts = (await getCollection('blog')).filter((post) => isPublicBlogPost(post, buildTime));
const relatedArticles = service.relatedArticleSlugs?.map((slug) => publicBlogPosts.find((post) => post.id === slug)).filter(Boolean).map(toBlogCardPost) ?? [];
const formatLocalParagraph = (paragraph: string) => paragraph.replace('{address}', `${business.address.street}, en ${business.address.locality}, ${business.address.province}`);
const jsonLd = [
  {'@context':'https://schema.org','@type':'WebPage',name:service.h1,description:service.metaDescription,url:site.siteUrl+path},
  {'@context':'https://schema.org','@type':'Service',name:service.h1,description:service.intro,areaServed:['La Zubia','Granada'],provider:{'@id':`${site.siteUrl}/#localbusiness`}},
  {'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:'Inicio',item:site.siteUrl+'/'},{'@type':'ListItem',position:2,name:'Servicios',item:site.siteUrl+'/servicios/'},{'@type':'ListItem',position:3,name:service.h1,item:site.siteUrl+path}]}
];
---
<BaseLayout title={service.seoTitle} description={service.metaDescription} path={path} jsonLd={jsonLd} backgroundDesktop={service.image} backgroundMobile={service.image}>
  <Breadcrumbs items={[{ label: 'Servicios', href: '/servicios/' }, { label: service.h1, href: path }]} />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Servicios</p>
      <h1 class="mt-3 text-4xl font-black">{service.h1}</h1>
      <p class="mt-4 max-w-3xl text-[var(--muted)]">{service.intro}</p>
      {service.relatedLinks && <nav class="mt-5 flex flex-wrap gap-3 text-sm" aria-label="Servicios y guías relacionadas">{service.relatedLinks.map((link)=><a class="btn" href={link.href}>{link.label}</a>)}</nav>}

      {service.commonProblems && service.commonProblems.length > 0 && (
        <section class="mt-10" aria-labelledby="problemas-habituales">
          <h2 id="problemas-habituales" class="text-2xl font-black">Problemas de ordenador y portátil que revisamos</h2>
          <p class="mt-4 max-w-3xl text-[var(--muted)]">Un mismo síntoma puede tener distintas causas. Por eso revisamos el equipo antes de recomendar una reparación, una mejora o un cambio de componente. Estos son algunos de los problemas que atendemos habitualmente en nuestro taller.</p>
          <div class="services-grid mt-5">
            {service.commonProblems.map((item)=><article class="card p-5"><h3 class="text-xl font-black">{item.title}</h3><p class="mt-2 text-[var(--muted)]">{item.description}</p></article>)}
          </div>
        </section>
      )}

      <h2 class="mt-10 text-2xl font-black">{service.groupHeading}</h2>
      <div class="services-grid mt-5">
        {service.services.map(item=><article class="card p-5"><h3 class="text-xl font-black">{item.title}</h3><p class="mt-2 text-[var(--muted)]">{item.description}</p></article>)}
      </div>

      {service.processSteps && service.processSteps.length > 0 && (
        <section class="mt-10" aria-labelledby="revision-equipo">
          <h2 id="revision-equipo" class="text-2xl font-black">Cómo revisamos tu ordenador o portátil</h2>
          <div class="grid-auto mt-5">
            {service.processSteps.map((step)=><article class="card p-5"><h3 class="text-xl font-black">{step.title}</h3><p class="mt-2 text-[var(--muted)]">{step.description}</p></article>)}
          </div>
        </section>
      )}

      {service.decisionSection && (
        <section class="mt-10 max-w-3xl" aria-labelledby="decision-reparacion">
          <h2 id="decision-reparacion" class="text-2xl font-black">{service.decisionSection.title}</h2>
          {service.decisionSection.paragraphs.map((paragraph)=><p class="mt-4 text-[var(--muted)]">{paragraph}</p>)}
        </section>
      )}

      {service.localSection && (
        <section class="mt-10 max-w-3xl" aria-labelledby="taller-local">
          <h2 id="taller-local" class="text-2xl font-black">{service.localSection.title}</h2>
          {service.localSection.paragraphs.map((paragraph)=><p class="mt-4 text-[var(--muted)]">{formatLocalParagraph(paragraph)}</p>)}
        </section>
      )}

      {relatedArticles.length > 0 && (
        <section class="mt-10" aria-labelledby="guias-relacionadas">
          <h2 id="guias-relacionadas" class="text-2xl font-black">Guías sobre ordenadores y portátiles</h2>
          <div class="grid-auto mt-5">
            {relatedArticles.map((post)=><article class="card p-6"><p class="eyebrow">Guía práctica</p><h3 class="mt-3 text-xl font-black"><a href={`/blog/${post.slug}/`}>{post.title}</a></h3><p class="mt-3 text-[var(--muted)]">{post.description}</p></article>)}
          </div>
        </section>
      )}

      {service.relatedServiceLinks && service.relatedServiceLinks.length > 0 && (
        <section class="mt-10" aria-labelledby="servicios-relacionados">
          <h2 id="servicios-relacionados" class="text-2xl font-black">Servicios relacionados</h2>
          <nav class="mt-5 flex flex-wrap gap-3 text-sm" aria-label="Servicios relacionados">
            {service.relatedServiceLinks.map((link)=><a class="btn" href={link.href}>{link.label}</a>)}
          </nav>
        </section>
      )}
    </div>
  </section>
  <CTASection title={service.ctaTitle ?? "Cuéntanos tu caso."} text="Cuéntanos qué ocurre o acércate al taller de La Zubia para revisar el equipo y valorar las opciones disponibles." />
</BaseLayout>
