---
import BaseLayout from '@/layouts/BaseLayout.astro';
const images=['/images/flopitec-fachada.webp','/images/flopitec-mostrador.webp','/images/flopitec-taller-reparacion.webp','/images/flopitec-equipo-reparando.webp','/images/flopitec-detalle-componentes.webp','/images/flopitec-consolas.webp','/images/flopitec-moviles.webp','/images/flopitec-segunda-vida.webp'];
---
<BaseLayout title="Galería | Flopitec" description="Espacio preparado para imágenes reales del taller Flopitec cuando estén disponibles." path="/galeria/"><section class="section"><div class="container"><p class="eyebrow">Galería</p><h1 class="mt-3 text-4xl font-black">Imágenes reales pendientes</h1><p class="mt-4 text-[var(--muted)]">Esta V1 no inventa fotografías. Los bloques indican las rutas preparadas para añadir imágenes reales después.</p><div class="mt-8 grid-auto">{images.map((image)=><div class="placeholder" role="img" aria-label={`Imagen pendiente: ${image}`}></div>)}</div></div></section></BaseLayout>
