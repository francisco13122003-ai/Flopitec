---
import BaseLayout from '@/layouts/BaseLayout.astro'; import CTASection from '@/components/CTASection.astro';
const images = ['fachada','mostrador','zona técnica'];
---
<BaseLayout title="Galería | Flopitec" description="Espacio preparado para imágenes reales del taller Flopitec cuando estén disponibles." path="/galeria/"><section class="section"><div class="container"><p class="eyebrow">Galería</p><h1 class="mt-3 text-4xl font-black">Imágenes reales pendientes</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Esta V1 no inventa fotografías. Los bloques indican espacios reservados para añadir fotos reales del taller cuando estén revisadas.</p><div class="mt-8 grid-auto">{images.map((image)=><div class="placeholder" role="img" aria-label={`Imagen real pendiente: ${image}`}></div>)}</div></div></section><CTASection title="¿Quieres conocer el taller?" text="Puedes visitarnos en La Zubia o consultar ubicación y horario en la página de contacto." /></BaseLayout>
