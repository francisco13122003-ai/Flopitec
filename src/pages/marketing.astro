---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import PriceSection from '@/components/MarketingPriceSection.astro';
import { business } from '@/data/business';
import { site } from '@/data/site';
import {
  marketingAnchorNav,
  marketingCategories,
  marketingCommercialNotices,
  marketingDiscounts,
  marketingEstimatorEnabled,
  marketingEstimatorHref,
  marketingEstimatorPath,
  marketingFaqs,
  marketingMaintenanceConditions,
  marketingMaintenancePlans,
  marketingPriceGroups,
  marketingSeo,
  marketingServices,
  marketingTrustMessages,
  marketingWebAddons,
  marketingWorkSteps,
} from '@/data/marketing';
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'WebPage', name: marketingSeo.h1, description: marketingSeo.description, url: site.siteUrl + marketingSeo.path },
  { '@context': 'https://schema.org', '@type': 'Service', name: 'Servicios de marketing para empresas', description: marketingSeo.description, areaServed: ['Granada', 'La Zubia'], provider: { '@id': `${site.siteUrl}/#localbusiness` } },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Inicio', item: site.siteUrl + '/' }, { '@type': 'ListItem', position: 2, name: 'Marketing', item: site.siteUrl + marketingSeo.path }] },
];
const estimatorA11y = marketingEstimatorEnabled ? undefined : 'La calculadora se habilitará en una fase posterior; este enlace lleva ahora a servicios y precios.';
---
<BaseLayout title={marketingSeo.title} description={marketingSeo.description} path={marketingSeo.path} jsonLd={jsonLd}>
  <Breadcrumbs items={[{ label: 'Marketing', href: '/marketing/' }]} />
  <section class="section marketing-hero"><div class="container hero-grid"><div><p class="eyebrow">Marketing, diseño y presencia digital</p><h1 class="mt-3 text-4xl font-black">Marketing para empresas en Granada</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Ayudamos a autónomos, comercios y empresas de Granada a mejorar su presencia digital y promocionar sus servicios. Creamos páginas web a medida, trabajamos el posicionamiento en Google, gestionamos redes sociales y publicidad y preparamos materiales digitales e impresos.</p><p class="mt-4 max-w-3xl text-[var(--muted)]">Puedes contratar un servicio concreto o combinar varias soluciones según lo que necesite tu negocio.</p><div class="mt-6 flex flex-wrap gap-3"><a class="btn btn-primary" href={marketingEstimatorHref} aria-describedby={!marketingEstimatorEnabled ? 'estimator-status' : undefined}>Configura tus servicios y calcula una estimación</a><a class="btn" href="#servicios-y-precios">Ver servicios y precios</a></div><p id="estimator-status" class="mt-3 text-sm text-[var(--muted)]">Precios orientativos de lanzamiento, indicados sin IVA. {!marketingEstimatorEnabled && 'La calculadora se activará en la siguiente fase.'}</p></div><ul class="trust-list card p-5">{marketingTrustMessages.map((item) => <li>{item}</li>)}</ul></div></section>
  <nav class="container anchor-nav" aria-label="Servicios de marketing">{marketingAnchorNav.map((item) => <a href={item.href}>{item.label}</a>)}</nav>

  <section class="section"><div class="container split-card card p-8"><div><h2 class="text-3xl font-black">Elige solo lo que necesita tu empresa</h2><p class="mt-4 text-[var(--muted)]">No todos los negocios necesitan una página web nueva, publicar todos los días o contratar una campaña de publicidad.</p><p class="mt-4 text-[var(--muted)]">Hemos preparado un asistente que te hará unas preguntas sencillas y te mostrará los servicios que pueden encajar con tus objetivos.</p><a class="btn btn-primary mt-6" href={marketingEstimatorHref} title={estimatorA11y}>Empezar mi estimación</a><p class="mt-3 text-sm text-[var(--muted)]">No necesitas registrarte ni facilitar tus datos para descargar el informe.</p></div><ul class="check-list">{['Revisar los servicios seleccionados.','Consultar una estimación desglosada.','Separar inversión inicial y cuotas mensuales.','Ver los costes externos por separado.','Descargar un informe en PDF.','Modificar cualquier selección.','Solicitar una propuesta definitiva.'].map((item) => <li>{item}</li>)}</ul></div></section>

  <section id="servicios-y-precios" class="section anchored"><div class="container"><p class="eyebrow">Servicios y precios</p><h2 class="mt-3 text-3xl font-black">Soluciones de marketing para negocios locales</h2><div class="services-grid mt-8">{marketingCategories.map((category) => <article class="card p-5"><h3 class="text-xl font-black"><a href={category.href}>{category.title}</a></h3><p class="price mt-3">{category.price}</p><p class="mt-3 text-[var(--muted)]">{category.description}</p><a class="inline-link mt-4" href={category.href}>Ver detalles</a></article>)}</div></div></section>

  <section id="paginas-web" class="section anchored"><div class="container"><h2 class="text-3xl font-black">Páginas web creadas a medida</h2><p class="mt-4 max-w-3xl text-[var(--muted)]">No utilizamos una plantilla prediseñada para cambiar únicamente los colores y el logotipo.</p><p class="mt-4 max-w-3xl text-[var(--muted)]">Diseñamos la estructura según el negocio y desarrollamos la página con código personalizado para que sea clara, rápida, adaptable y fácil de ampliar.</p><div class="grid-auto mt-8">{marketingServices.map((service) => <article class="card p-5"><h3 class="text-xl font-black">{service.name}</h3>{service.priceFrom && <p class="price mt-3">Desde {service.priceFrom.toLocaleString('es-ES')} € {service.priceSuffix}</p>}{service.prices?.map((price) => <p class="price mt-3">{price}</p>)}<p class="mt-3 text-[var(--muted)]">{service.shortDescription}</p>{service.note && <p class="notice mt-4">{service.note}</p>}{service.featuredItems && <><h4 class="mt-4 font-black">Incluye o depende de</h4><ul class="compact-list">{service.featuredItems.map((item) => <li>{item}</li>)}</ul></>}{service.exclusions && <><h4 class="mt-4 font-black">Presupuesto separado</h4><ul class="compact-list">{service.exclusions.map((item) => <li>{item}</li>)}</ul></>}</article>)}</div><article class="card p-5 mt-6"><h3 class="text-xl font-black">Complementos web</h3><ul class="compact-list columns-list">{marketingWebAddons.map((item) => <li>{item}</li>)}</ul></article></div></section>

  <PriceSection id="seo-google" title="Ayudamos a que Google entienda mejor tu negocio" intro={['El SEO no consiste únicamente en repetir palabras clave.','Revisamos cómo está construida la web, qué información encuentran los buscadores, qué consultas realizan los posibles clientes y cómo aparece la empresa en Google y otros servicios.','Después priorizamos las mejoras que pueden aportar más claridad, visibilidad y oportunidades de contacto.']} groups={[{title:'Servicios SEO',items:marketingPriceGroups.seo}]} notices={['No garantizamos posiciones concretas, un número determinado de visitas ni resultados inmediatos.']} />
  <PriceSection id="redes-sociales" title="Redes que representen correctamente a tu empresa" intro={['Podemos ayudarte tanto a crear los perfiles como a mantenerlos activos.','Configuramos la información, preparamos el diseño, planificamos contenidos, publicamos y gestionamos mensajes y comentarios dentro del alcance acordado.']} groups={[{title:'Redes sociales',items:marketingPriceGroups.social},{title:'Community management',items:marketingPriceGroups.community}]} notices={['No ofrecemos atención permanente ni respuesta inmediata las veinticuatro horas.']} />
  <PriceSection id="publicidad-digital" title="Campañas en Google, Facebook e Instagram" intro={['Configuramos y gestionamos campañas para promocionar servicios, productos, ofertas o eventos.']} groups={[{title:'Preparación inicial, gestión mensual, diseño, landing page y presupuesto publicitario',items:marketingPriceGroups.ads}]} notices={['El dinero destinado a Google, Facebook o Instagram se muestra separado de nuestros honorarios.','El presupuesto publicitario, la configuración inicial y la gestión del primer mes se abonan por adelantado.','Flopitec no financia campañas publicitarias.','No garantizamos un número concreto de ventas, contactos o visitas.']} />
  <PriceSection id="diseno-impresion" title="Materiales que transmitan una imagen coherente" groups={[{title:'Diseño gráfico',items:marketingPriceGroups.design},{title:'Tarifa de gestión de imprenta',items:marketingPriceGroups.printManagement},{title:'Buzoneo',items:marketingPriceGroups.leaflet}]} notices={['Los logotipos incluyen dos propuestas iniciales y dos rondas de cambios sobre la propuesta elegida.','Los demás diseños gráficos incluyen una propuesta inicial y dos rondas de cambios, salvo que el presupuesto indique otras condiciones.','El diseño, la impresión, la gestión, el transporte extraordinario y el reparto se muestran por separado.','El reparto de 1.000 unidades suele requerir aproximadamente diez horas y puede realizarse durante una o dos semanas.']} />
  <PriceSection id="fotografia-video" title="Contenido visual para presentar mejor tu negocio" intro={['Disponemos de cámaras, estabilizadores y equipos para crear contenido adaptado a páginas web, redes sociales y campañas publicitarias.']} groups={[{title:'Fotografía, vídeo y dron',items:marketingPriceGroups.visual}]} notices={['Los servicios con dron están sujetos a ubicación, normativa aplicable, seguridad, condiciones meteorológicas, restricciones del espacio aéreo, permisos y viabilidad técnica.']} />
  <PriceSection id="comunicacion-digital" title="Herramientas para atender y mantener el contacto" groups={[{title:'Comunicación digital',items:marketingPriceGroups.communication}]} notices={['Las licencias, cuotas de proveedor y dominio se muestran por separado.','Solo trabajamos con bases de datos y contactos obtenidos legítimamente.']} />

  <section id="mantenimiento" class="section anchored"><div class="container"><h2 class="text-3xl font-black">Podemos seguir trabajando después de la entrega</h2><div class="grid-auto mt-8">{marketingMaintenancePlans.map((plan) => <article class="card p-5"><h3 class="text-xl font-black">{plan.name}</h3><p class="price mt-3">{plan.monthly}</p><p class="price annual">{plan.annual}</p><ul class="compact-list">{plan.items.map((item) => <li>{item}</li>)}</ul></article>)}</div><ul class="notice-list mt-6">{marketingMaintenanceConditions.map((item) => <li>{item}</li>)}</ul></div></section>

  <section class="section"><div class="container grid-auto"><article class="card p-6"><h2 class="text-3xl font-black">Cómo trabajamos</h2><ol class="compact-list numbered">{marketingWorkSteps.map((step) => <li>{step}</li>)}</ol><h3 class="mt-5 text-xl font-black">Condiciones de pago</h3><ul class="compact-list"><li>50 % al aceptar.</li><li>30 % al aprobar la fase principal.</li><li>20 % antes de publicar o entregar.</li><li>En trabajos pequeños puede solicitarse el pago completo al comenzar.</li></ul></article><article class="card p-6"><h2 class="text-3xl font-black">{marketingDiscounts.title}</h2><p class="mt-4 text-[var(--muted)]">{marketingDiscounts.text}</p><ul class="compact-list">{marketingDiscounts.items.map((item) => <li>{item}</li>)}</ul><h3 class="mt-5 text-xl font-black">Exclusiones</h3><ul class="tag-list">{marketingDiscounts.exclusions.map((item) => <li>{item}</li>)}</ul></article></div></section>

  <section class="section"><div class="container"><h2 class="text-3xl font-black">Preguntas frecuentes</h2><div class="faq-grid mt-8">{marketingFaqs.map(([q,a]) => <article class="card p-5"><h3 class="text-lg font-black">{q}</h3><p class="mt-3 text-[var(--muted)]">{a}</p></article>)}</div></div></section>
  <section class="section"><div class="container card p-8 text-center"><h2 class="text-3xl font-black">Configura una propuesta adaptada a tu negocio</h2><p class="mx-auto mt-3 max-w-2xl text-[var(--muted)]">Selecciona los servicios que necesitas y obtén una estimación inicial desglosada.</p><p class="mx-auto mt-3 max-w-2xl text-[var(--muted)]">Podrás revisar la inversión inicial, las cuotas mensuales, los costes externos y los posibles descuentos antes de descargar el informe.</p><div class="mt-6 flex flex-wrap justify-center gap-3"><a class="btn btn-primary" href={marketingEstimatorHref}>Calcular mi estimación</a><a class="btn" href="/contacto/">Contactar con Flopitec</a></div><p class="mt-3 text-sm text-[var(--muted)]">La descarga del informe no requiere registro ni datos personales.</p></div></section>
  <section class="section legal-note"><div class="container"><div class="card p-6"><h2 class="text-xl font-black">Aviso legal comercial</h2>{marketingCommercialNotices.map((notice) => <p class="mt-3 text-sm text-[var(--muted)]">{notice}</p>)}<nav class="mt-5 flex flex-wrap gap-3 text-sm" aria-label="Enlaces internos"><a href="/servicios/soporte-empresas/">Empresas</a><a href="/contacto/">Contacto</a><a href="/sobre-nosotros/">Sobre nosotros</a><a href="/blog/">Blog</a>{marketingEstimatorEnabled && <a href={marketingEstimatorPath}>Calculadora de marketing</a>}</nav></div></div></section>
</BaseLayout>

<style>
  .anchored{scroll-margin-top:7rem}.hero-grid,.split-card{display:grid;gap:1.5rem;align-items:center}.hero-grid{grid-template-columns:minmax(0,1.5fr) minmax(260px,.7fr)}.trust-list,.check-list,.compact-list,.notice-list{display:grid;gap:.65rem}.trust-list{list-style:'✓ ';padding-left:2rem}.check-list{padding-left:1.2rem}.anchor-nav{display:flex;gap:.8rem;overflow-x:auto;padding-block:1rem;border-block:1px solid var(--line);scrollbar-width:thin}.anchor-nav a{display:inline-flex;align-items:center;justify-content:center;min-height:2.75rem;padding:.75rem 1rem;border:1px solid var(--line);border-radius:999px;background:var(--surface);box-shadow:0 8px 22px color-mix(in srgb,var(--ink) 8%,transparent);color:var(--accent);font-weight:900;white-space:nowrap;transition:transform .18s ease,border-color .18s ease,background .18s ease}.anchor-nav a:hover,.anchor-nav a:focus-visible{transform:translateY(-2px);border-color:var(--accent);background:color-mix(in srgb,var(--accent) 10%,var(--surface));outline:none}.inline-link{color:var(--accent);font-weight:800;white-space:nowrap}.price{color:var(--accent);font-weight:950;font-size:1.05rem}.annual{color:var(--ink);font-size:.95rem}.notice,.notice-list{border-left:3px solid var(--accent);padding:.85rem 1rem;background:color-mix(in srgb,var(--accent) 10%,transparent);border-radius:.8rem}.compact-list{margin-top:1rem;padding-left:1.2rem}.columns-list{columns:2 260px}.numbered{list-style:decimal;padding-left:1.5rem}.tag-list{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1rem;padding:0;list-style:none}.tag-list li{border:1px solid var(--line);border-radius:999px;padding:.4rem .65rem;color:var(--muted)}.faq-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.legal-note{padding-top:0}.price-card-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,250px),1fr));gap:1rem}.price-section:nth-of-type(even){background:color-mix(in srgb,var(--soft) 78%,transparent)}@media (max-width:760px){.hero-grid,.split-card,.faq-grid{grid-template-columns:1fr}.trust-list{padding-left:1.7rem}.anchor-nav{width:min(1120px,calc(100vw - 2rem))}}@media (max-width:420px){.services-grid{grid-template-columns:1fr}.btn{width:100%}}
</style>
