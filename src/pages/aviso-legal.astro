---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { business } from '@/data/business';
---
<BaseLayout title="Aviso legal | Flopitec" description="Aviso legal base de Flopitec pendiente de revisión profesional." path="/aviso-legal/"><section class="section"><div class="container max-w-3xl"><h1 class="text-4xl font-black">Aviso legal</h1><p class="mt-4 text-[var(--muted)]">Texto base pendiente de revisión profesional antes de publicación definitiva.</p><h2 class="mt-8 text-2xl font-black">Responsable</h2><p>{business.legalName} · NIF {business.nif}</p><p>{business.address.full}</p><p><a href={business.emailHref}>{business.email}</a></p><h2 class="mt-8 text-2xl font-black">Uso de la web</h2><p class="text-[var(--muted)]">La información es corporativa e informativa. No constituye asesoramiento legal definitivo.</p><div class="mt-8"><a class="btn btn-primary" href="/contacto/">Contactar con Flopitec</a></div></div></section></BaseLayout>
