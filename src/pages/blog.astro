---
import BaseLayout from '@/layouts/BaseLayout.astro'; import BlogCard from '@/components/BlogCard.astro'; import { blogPosts } from '@/data/blog';
---
<BaseLayout title="Blog informático | Flopitec" description="Guías sencillas sobre reparación, SSD, Windows 11 y portátiles para clientes de La Zubia y Granada." path="/blog/"><section class="section"><div class="container"><p class="eyebrow">Blog</p><h1 class="mt-3 text-4xl font-black">Guías prácticas sin tecnicismos innecesarios</h1><div class="mt-8 grid-auto">{blogPosts.map(post=><BlogCard post={post}/>)}</div></div></section></BaseLayout>
