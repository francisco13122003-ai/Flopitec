---
import BaseLayout from '@/layouts/BaseLayout.astro'; import BlogCard from '@/components/BlogCard.astro'; import CTASection from '@/components/CTASection.astro'; import { blogPosts } from '@/data/blog';
---
<BaseLayout title="Consejos de reparación y mantenimiento informático | Flopitec" description="Consejos de reparación y mantenimiento informático para cuidar ordenadores y portátiles. Guías prudentes del taller Flopitec en La Zubia." path="/blog/"><section class="section"><div class="container"><p class="eyebrow">Blog</p><h1 class="mt-3 text-4xl font-black">Consejos sobre reparación y mantenimiento informático</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Artículos breves para orientar antes de reparar, ampliar o actualizar un equipo. No sustituyen una revisión técnica presencial.</p><div class="mt-8 grid-auto">{blogPosts.map(post=><BlogCard post={post}/>)}</div></div></section><CTASection title="¿Prefieres que revisemos tu caso?" text="Si tienes dudas con tu ordenador, portátil o móvil, escríbenos por WhatsApp o consulta las vías de contacto." /></BaseLayout>
