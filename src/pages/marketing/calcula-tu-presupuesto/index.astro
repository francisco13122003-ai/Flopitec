  { id: 'web', title: 'Crear o mejorar mi página web', description: 'Para presentar tu empresa, explicar tus servicios, recibir consultas, gestionar reservas o vender por Internet.' },
  { id: 'seo', title: 'Aparecer mejor en Google', description: 'Para que más personas encuentren tu empresa cuando busquen tus servicios o consulten negocios de Granada.' },
  { id: 'redes', title: 'Crear o gestionar redes sociales', description: 'Para tener perfiles profesionales, publicar contenido y mantener el contacto con clientes.' },
  { id: 'publicidad', title: 'Lanzar anuncios en Internet', description: 'Para promocionar un servicio, producto u oferta en Google, Facebook o Instagram.' },
  { id: 'diseno', title: 'Diseñar logotipo o material publicitario', description: 'Para crear una imagen de marca, flyers, tarjetas, carteles, menús u otros materiales.' },
  { id: 'foto', title: 'Crear fotografías o vídeos profesionales', description: 'Para mostrar mejor tu negocio, instalaciones, productos o servicios en la web y las redes.' },
  { id: 'comunicacion', title: 'Mejorar cómo atiendo a mis clientes', description: 'Para configurar WhatsApp Business, correo corporativo, newsletters o respuestas automáticas.' },
  { id: 'mantenimiento', title: 'Tener ayuda después de la entrega', description: 'Para mantener la web actualizada, hacer pequeños cambios y resolver incidencias.' },
  { id: 'no-se', title: 'No tengo claro qué necesito', description: 'Selecciona esta opción y te mostraremos las alternativas más habituales para orientarte.' },
];

const steps = [
  { id: 'objetivo', area: 'Inicio', title: '¿Qué quieres mejorar en tu empresa?', intro: 'Puedes seleccionar varias opciones. No necesitas conocer términos de marketing: en los siguientes pasos te explicaremos cada servicio con ejemplos sencillos.', kind: 'goals' },
  { id: 'web-tipo', group: 'web', area: 'Web 1 — Tipo de página', title: '¿Qué tipo de página necesita tu empresa?', intro: 'Selecciona la opción que más se parezca a lo que quieres conseguir. Después podrás indicar páginas, contenidos y funciones adicionales.', help: 'Landing: una sola página y un objetivo concreto. Web básica: opción habitual para una pequeña o mediana empresa. Web ampliada: varios servicios o áreas independientes. Catálogo: mostrar productos sin vender desde la web. Tienda: vender, cobrar y gestionar pedidos online.' },
  { id: 'web-contenido', group: 'web', area: 'Web 2 — Tamaño y contenido', title: '¿Necesitas ampliar contenido o estructura?', intro: 'Marca solo los complementos que tengan sentido para la web elegida. Estos complementos no cuentan como un servicio principal adicional para el tramo de descuento.' },
  { id: 'web-funciones', group: 'web', area: 'Web 3 — Funciones adicionales', title: '¿La web necesita funciones especiales?', intro: 'Las funciones conectadas con sistemas externos, reservas o comercio avanzado necesitan revisión técnica antes de confirmar el precio.' },
  { id: 'seo', group: 'seo', area: 'Google y SEO', title: '¿Cómo quieres mejorar tu presencia en buscadores?', intro: 'SEO significa preparar la web y la información del negocio para que Google entienda mejor lo que ofreces.' },
  { id: 'redes-perfiles', group: 'redes', area: 'Redes 1 — Configuración de perfiles', title: '¿Necesitas preparar tus redes sociales?', intro: 'Esta parte sirve para que tus perfiles tengan información, imagen y enlaces coherentes antes de publicar contenido.' },
  { id: 'redes-contenido', group: 'redes', area: 'Redes 2 — Publicaciones y contenido', title: '¿Con qué frecuencia quieres publicar?', intro: 'Elige un ritmo mensual aproximado. 4 publicaciones es presencia mínima, 8 actividad regular y 12 comunicación frecuente.', help: '4 publicaciones: presencia mínima. 8 publicaciones: actividad regular. 12 publicaciones: comunicación frecuente.' },
  { id: 'redes-comunidad', group: 'redes', area: 'Redes 3 — Mensajes y comentarios', title: '¿Quieres ayuda respondiendo mensajes?', intro: 'Community management significa revisar y responder mensajes y comentarios dentro de un horario y alcance acordados. No es atención 24 horas.' },
  { id: 'publicidad', group: 'publicidad', area: 'Publicidad digital', title: '¿Qué necesitas para lanzar anuncios?', intro: 'La publicidad digital tiene dos costes separados: nuestro trabajo de configuración y gestión, y el dinero que se entrega a Google, Facebook o Instagram para mostrar los anuncios.', help: 'Google Ads aparece cuando alguien busca un servicio. Facebook e Instagram muestran anuncios por ubicación, intereses y otros criterios. Puedes combinar ambos enfoques.' },
  { id: 'diseno-necesidad', group: 'diseno', area: 'Diseño 1 — Qué necesita diseñar', title: '¿Qué material necesita tu empresa?', intro: 'Los diseños se calculan como trabajo creativo. Si necesitas imprimir, el coste de imprenta se separa en el siguiente paso.' },
  { id: 'diseno-impresion', group: 'diseno', area: 'Diseño 2 — Impresión', title: '¿Necesitas imprimir o contratar un proveedor externo?', intro: 'Separar la impresión evita mezclar nuestros honorarios con costes de terceros.' },
  { id: 'diseno-reparto', group: 'diseno', area: 'Diseño 3 — Reparto y desplazamientos', title: '¿Hace falta reparto, buzoneo o desplazamiento?', intro: 'Estas partidas dependen de zona, volumen y disponibilidad, por eso se marcan como pendientes de valoración.' },
  { id: 'foto-tipo', group: 'foto', area: 'Fotografía y vídeo 1 — Tipo de contenido', title: '¿Qué contenido visual necesitas?', intro: 'Elige si necesitas fotografías del negocio, productos o contenido audiovisual.' },
  { id: 'foto-cantidad', group: 'foto', area: 'Fotografía y vídeo 2 — Cantidad o duración', title: '¿Necesitas piezas adicionales o vídeo?', intro: 'Los packs y vídeos más amplios dependen de duración, localizaciones, guion y edición.' },
  { id: 'foto-dron', group: 'foto', area: 'Fotografía y vídeo 3 — Ubicación y dron', title: '¿Necesitas imágenes aéreas con dron?', intro: 'El dron depende de ubicación, normativa, seguridad, meteorología, permisos y viabilidad técnica.' },
  { id: 'comunicacion', group: 'comunicacion', area: 'Comunicación digital', title: '¿Cómo quieres atender y comunicarte con clientes?', intro: 'Estas opciones ayudan a ordenar WhatsApp, correo y comunicaciones. En email marketing solo se trabaja con contactos que hayan aceptado recibir comunicaciones.' },
  { id: 'mantenimiento', group: 'mantenimiento', area: 'Mantenimiento', title: '¿Quieres soporte después de la entrega?', intro: 'El mantenimiento cubre ayuda posterior, cambios pequeños y revisión según el plan elegido.' },
  { id: 'resumen', area: 'Resumen editable', title: 'Resumen editable', intro: 'Revisa, ajusta importes y descarga el informe.' },
];
---
<BaseLayout title={title} description={description} path={marketingEstimatorPath}>
  <Breadcrumbs items={[{ label: 'Marketing', href: '/marketing/' }, { label: 'Calculadora', href: marketingEstimatorPath }]} />
  <main class="section estimator" data-options={JSON.stringify(options)} data-steps={JSON.stringify(steps)} data-goals={JSON.stringify(goals)} data-business={JSON.stringify(business)}>
    <div class="container estimator-shell">
      <p class="eyebrow">Calculadora de marketing</p>
      <h1 class="mt-3 text-4xl font-black">Calcula tu presupuesto orientativo</h1>
      <p class="estimator-lead mt-4">Selecciona servicios paso a paso. La estimación separa inversión inicial, descuentos, cuotas, publicidad, costes externos y partidas pendientes de valoración. No solicitamos datos personales.</p>
      <noscript><p class="notice mt-6">Activa JavaScript para utilizar la calculadora y descargar la estimación en PDF.</p></noscript>
      <div class="progress-card card p-5 mt-8" aria-live="polite"><div class="progress-meta"><strong id="stepLabel">Paso 1 de 1 · 0%</strong><span id="progressText">0%</span></div><div class="progress-track" id="progressBarWrap" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-describedby="stepLabel"><span id="progressBar"></span></div></div>
      <section id="stepPanel" class="estimator-panel card p-6 mt-6" tabindex="-1"></section>
      <p id="formError" class="error-message" role="alert" aria-live="assertive" hidden></p>
      <div class="estimator-actions mt-5"><button class="btn" id="prevStep" type="button">Anterior</button><span class="estimator-actions__secondary"><button class="btn" id="resetEstimator" type="button">Reiniciar estimación</button><button class="btn btn-primary" id="nextStep" type="button">Siguiente</button></span></div>
      <section id="summaryPanel" class="summary-print card p-6 mt-6" hidden></section>
    </div>
  </main>
</BaseLayout>
<script>
  const storageKey = 'flopitec-marketing-estimator-v1';
  const root = document.querySelector('.estimator');
  const options = JSON.parse(root.dataset.options);
  const steps = JSON.parse(root.dataset.steps);
  const goals = JSON.parse(root.dataset.goals);
  const business = JSON.parse(root.dataset.business);
  const selectedGoals = new Set(['web']);
  const selected = new Set();
  let current = 0;
  const fmt = (n) => `${Number(n || 0).toLocaleString('es-ES', { minimumFractionDigits: Number.isInteger(Number(n || 0)) ? 0 : 2, maximumFractionDigits: 2 })} €`;
  const dateStamp = () => new Date().toLocaleDateString('sv-SE');
  const refStamp = () => { const d = new Date(); return `MKT-${dateStamp().replaceAll('-', '')}-${String(d.getHours()).padStart(2, '0')}${String(d.getMinutes()).padStart(2, '0')}`; };
  const visibleSteps = () => steps.filter((s) => s.kind === 'goals' || s.id === 'resumen' || selectedGoals.has(s.group));
  const optionById = (id) => options.find((option) => option.id === id);
  const discountUnitCount = (items) => items.filter((o)=>o.discountable && o.initial && o.countForDiscount !== false).length;
  const discountRate = (count) => count >= 5 ? .08 : count >= 3 ? .05 : count >= 2 ? .03 : 0;
  const totals = () => {
    const items = options.filter((o) => selected.has(o.id));
    const initialItems = items.filter((o) => !o.pending && o.initial);
    const monthlyOwnItems = items.filter((o) => !o.pending && o.monthly);
    const annualItems = items.filter((o) => !o.pending && o.annual);
    const adItems = items.filter((o) => !o.pending && o.adBudget);
    const externalItems = items.filter((o) => !o.pending && o.external);
    const initial = initialItems.reduce((a,o)=>a+(o.initial||0),0);
    const monthlyOwn = monthlyOwnItems.reduce((a,o)=>a+(o.monthly||0),0);
    const annual = annualItems.reduce((a,o)=>a+(o.annual||0),0);
    const ad = adItems.reduce((a,o)=>a+(o.adBudget||0),0);
    const external = externalItems.reduce((a,o)=>a+(o.external||0),0);
    const count = discountUnitCount(items);
    const rate = discountRate(count);
    const discountBase = initialItems.filter((o)=>o.discountable).reduce((a,o)=>a+(o.initial||0),0);
    const discount = Number((discountBase * rate).toFixed(2));
    return { items, initial, monthlyOwn, annual, ad, external, discount, rate, totalOneTime: Number((initial - discount).toFixed(2)) };
  };
  function saveState(){ sessionStorage.setItem(storageKey, JSON.stringify({ goals:[...selectedGoals], selected:[...selected], current })); }
  function restoreState(){ try { const state = JSON.parse(sessionStorage.getItem(storageKey) || 'null'); if(!state) return; selectedGoals.clear(); state.goals?.forEach((id)=>selectedGoals.add(id)); selected.clear(); state.selected?.forEach((id)=>selected.add(id)); current = Number(state.current || 0); } catch { sessionStorage.removeItem(storageKey); } }
  function showError(message){ const error = document.getElementById('formError'); error.textContent = message; error.hidden = !message; }
  function validateSummary(){ const invalid = [...document.querySelectorAll('[data-total]')].find((input) => input.value === '' || Number.isNaN(Number(input.value)) || Number(input.value) < 0); showError(invalid ? 'Introduce importes válidos iguales o superiores a 0 € antes de descargar el PDF.' : ''); return !invalid; }
  function priceText(option){ return option.pending ? 'Pendiente de valoración' : option.priceLabel || [option.initial&&`Inicial ${fmt(option.initial)}`, option.monthly&&`Mensual ${fmt(option.monthly)}`, option.annual&&`Anual ${fmt(option.annual)}`, option.adBudget&&`Publicidad ${fmt(option.adBudget)}/mes`, option.external&&`Externo ${fmt(option.external)}`].filter(Boolean).join(' · '); }
  function optionCard(option, inputName){
    const checked = selected.has(option.id) ? 'checked' : '';
    const includes = option.includes?.length ? `<details class="estimator-option__details"><summary>Ver qué incluye</summary><ul>${option.includes.map((item) => `<li>${item}</li>`).join('')}</ul></details>` : '';
    return `<label class="estimator-option"><input type="checkbox" name="${inputName}" data-service="${option.id}" ${checked}><span class="estimator-option__check" aria-hidden="true"></span><span class="estimator-option__content"><span class="estimator-option__header"><strong>${option.title || option.name}</strong>${option.badge ? `<span class="badge">${option.badge}</span>` : ''}</span><span class="estimator-option__description">${option.description || option.desc}</span>${option.bestFor ? `<span class="estimator-option__best-for"><strong>Te conviene si:</strong> ${option.bestFor}</span>` : ''}${includes}${option.requiresReview ? '<span class="review-note">Necesita revisión antes de confirmar el precio.</span>' : ''}<span class="estimator-option__footer"><span>${option.billingLabel || 'Estimación'}</span><strong>${priceText(option)}</strong></span><span class="selected-text" aria-live="polite">Seleccionado</span></span></label>`;
  }
  function goalCard(goal){ return `<label class="estimator-option estimator-option--goal"><input type="checkbox" data-goal="${goal.id}" ${selectedGoals.has(goal.id)?'checked':''}><span class="estimator-option__check" aria-hidden="true"></span><span class="estimator-option__content"><span class="estimator-option__header"><strong>${goal.title}</strong></span><span class="estimator-option__description">${goal.description}</span><span class="selected-text" aria-live="polite">Seleccionado</span></span></label>`; }
  function render(){
    const list = visibleSteps(); if(current >= list.length) current = list.length - 1;
    const step = list[current]; const pct = list.length > 1 ? Math.round((current / (list.length - 1)) * 100) : 100;
    document.getElementById('stepLabel').textContent = `Paso ${current + 1} de ${list.length} · ${pct}%`;
    document.getElementById('progressText').textContent = `${pct}%`;
    document.getElementById('progressBar').style.width = `${pct}%`;
    document.getElementById('progressBarWrap').setAttribute('aria-valuenow', String(pct));
    document.getElementById('prevStep').disabled = current === 0;
    document.getElementById('nextStep').textContent = step.id === 'resumen' ? 'Actualizar resumen' : current === list.length - 2 ? 'Ver resumen' : 'Siguiente';
    const panel = document.getElementById('stepPanel'); document.getElementById('summaryPanel').hidden = step.id !== 'resumen'; showError('');
    if(step.kind === 'goals'){
      panel.innerHTML = `<fieldset><legend><span class="step-area">${step.area}</span><h2 tabindex="-1">${step.title}</h2></legend><p class="step-intro">${step.intro}</p><div class="option-grid option-grid--goals">${goals.map(goalCard).join('')}</div></fieldset>`;
    } else {
      const cards = options.filter(o=>o.step===step.id).map((option)=>optionCard(option, `services-${step.id}`)).join('');
      panel.innerHTML = `<fieldset><legend><span class="step-area">${step.area}</span><h2 tabindex="-1">${step.title}</h2></legend><p class="step-intro">${step.intro}</p>${step.help ? `<aside class="choice-help"><strong>¿Cuál elegir?</strong><p>${step.help}</p></aside>` : ''}<div class="option-grid">${cards}</div></fieldset>`;
    }
    panel.querySelectorAll('[data-goal]').forEach(i=>i.addEventListener('change', e=> { e.target.checked ? selectedGoals.add(e.target.dataset.goal) : selectedGoals.delete(e.target.dataset.goal); if(e.target.dataset.goal === 'no-se' && e.target.checked){ ['web','seo','redes'].forEach((id)=>selectedGoals.add(id)); } saveState(); render(); }));
    panel.querySelectorAll('[data-service]').forEach(i=>i.addEventListener('change', e=> { e.target.checked ? selected.add(e.target.dataset.service) : selected.delete(e.target.dataset.service); saveState(); }));
    if(step.id === 'resumen') renderSummary();
    panel.scrollIntoView({ behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth', block: 'start' });
    panel.querySelector('h2')?.focus?.({ preventScroll: true }); saveState();
  }
  function editableRows(){ const t = totals(); return [['initial', 'Inversión inicial', t.initial], ['discount', 'Descuento', t.discount], ['totalOneTime', 'Total puntual', t.totalOneTime], ['monthlyOwn', 'Servicios mensuales', t.monthlyOwn], ['annual', 'Servicios anuales', t.annual], ['ad', 'Presupuesto publicitario separado', t.ad], ['external', 'Costes externos', t.external]]; }
  function summaryItem(item){ return `<article class="summary-item"><div><strong>${item.name}</strong><p>${item.desc}</p></div><span class="summary-pill">${item.pending ? 'Pendiente de valoración' : item.billingLabel || item.type}</span><span class="summary-price">${priceText(item)}</span><button class="btn btn-small" type="button" data-remove="${item.id}">Eliminar</button></article>`; }
  function renderSummary(){
    const t = totals(); const groups = [ ['initial', 'Inversión inicial', t.items.filter((o)=>!o.pending && o.initial)], ['monthly', 'Servicios mensuales', t.items.filter((o)=>!o.pending && o.monthly)], ['annual', 'Servicios anuales', t.items.filter((o)=>!o.pending && o.annual)], ['ad', 'Publicidad', t.items.filter((o)=>!o.pending && o.adBudget)], ['external', 'Costes externos', t.items.filter((o)=>!o.pending && o.external)], ['pending', 'Pendientes de valoración', t.items.filter((o)=>o.pending)] ];
    document.getElementById('summaryPanel').innerHTML = `<div id="pdfReport"><p class="eyebrow">Resumen de estimación</p><h2>Propuesta orientativa de marketing</h2><p><strong>Referencia:</strong> ${refStamp()}</p><p><strong>Objetivos seleccionados:</strong> ${[...selectedGoals].map(id => goals.find(goal=>goal.id===id)?.title).filter(Boolean).join(', ')}</p><div class="summary-grid">${editableRows().map(([key,k,v])=>`<label for="total-${key}"><span>${k}</span><input id="total-${key}" type="number" min="0" step="0.01" value="${v}" data-total="${key}" aria-describedby="formError"></label>`).join('')}</div><div class="summary-sections">${groups.map(([id, label, items])=>`<section class="summary-section"><h3>${label}</h3>${items.length ? items.map(summaryItem).join('') : '<p class="muted">Sin partidas en este bloque.</p>'}</section>`).join('')}</div><p class="notice">Información sin IVA. Estimación no contractual y sin garantías de resultados.</p></div><button class="btn btn-primary mt-5" id="downloadPdf" type="button">Descargar PDF</button>`;
    document.querySelectorAll('[data-total]').forEach((input)=>input.addEventListener('input', validateSummary));
    document.querySelectorAll('[data-remove]').forEach((button)=>button.addEventListener('click', (event)=>{ selected.delete(event.currentTarget.dataset.remove); renderSummary(); saveState(); }));
    document.getElementById('downloadPdf').addEventListener('click', downloadPdf);
  }
  const encodeUtf16Hex = (text) => Array.from(new TextEncoder().encode(String(text))).length && Array.from(String(text)).flatMap((char) => { const code = char.charCodeAt(0); return [code >> 8, code & 255]; }).map((byte) => byte.toString(16).padStart(2, '0')).join('');
  const pdfText = (value) => `<FEFF${encodeUtf16Hex(value)}>`;
  const wrap = (text, max = 78) => String(text).split(' ').reduce((lines, word) => { const line = lines[lines.length - 1] || ''; if((line + ' ' + word).trim().length > max) lines.push(word); else lines[lines.length - 1] = (line + ' ' + word).trim(); return lines; }, ['']);
  function buildPdf(blocks){
    const pages = []; let currentPage = []; let y = 792;
    const footerSpace = 54;
    const addPage = () => { pages.push(currentPage); currentPage = []; y = 792; };
    blocks.forEach(({ text, size = 10, bold = false, gap = 16 }) => { if(y - gap < footerSpace) addPage(); currentPage.push({ text, size, bold, y }); y -= gap; });
    pages.push(currentPage);
    const objects = ['<< /Type /Catalog /Pages 2 0 R >>', '', '<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>', '<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold /Encoding /WinAnsiEncoding >>'];
    const pageRefs = [];
    pages.forEach((page, index) => {
      const content = ['0.95 0.97 1 rg 0 760 595 82 re f', '0.05 0.24 0.42 rg 0 760 595 6 re f'];
      page.forEach((line) => content.push(`BT /${line.bold ? 'F2' : 'F1'} ${line.size} Tf 54 ${line.y} Td ${pdfText(line.text)} Tj ET`));
      content.push(`BT /F1 9 Tf 54 32 Td ${pdfText(`${business.commercialName} · Página ${index + 1} de ${pages.length}`)} Tj ET`);
      const contentNumber = objects.length + 2;
      pageRefs.push(`${objects.length + 1} 0 R`);
      objects.push(`<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] /Resources << /Font << /F1 3 0 R /F2 4 0 R >> >> /Contents ${contentNumber} 0 R >>`);
      objects.push(`<< /Length ${content.join('\n').length} >>\nstream\n${content.join('\n')}\nendstream`);
    });
    objects[1] = `<< /Type /Pages /Kids [${pageRefs.join(' ')}] /Count ${pages.length} >>`;
    let pdf = '%PDF-1.4\n'; const offsets = [0]; objects.forEach((obj, index) => { offsets.push(pdf.length); pdf += `${index + 1} 0 obj\n${obj}\nendobj\n`; });
    const xref = pdf.length; pdf += `xref\n0 ${objects.length + 1}\n0000000000 65535 f \n` + offsets.slice(1).map((offset) => `${String(offset).padStart(10, '0')} 00000 n `).join('\n') + `\ntrailer\n<< /Size ${objects.length + 1} /Root 1 0 R >>\nstartxref\n${xref}\n%%EOF`;
    return new Blob([pdf], { type: 'application/pdf' });
  }
  function downloadPdf(){
    if(!validateSummary()) return;
    const t = totals();
    const edited = Object.fromEntries([...document.querySelectorAll('[data-total]')].map((input) => [input.dataset.total, Number(input.value)]));
    const blocks = [
      { text: 'Flopitec', size: 18, bold: true, gap: 22 }, { text: 'Propuesta orientativa de marketing', size: 16, bold: true, gap: 22 }, { text: `Fecha: ${dateStamp()} · Referencia ${refStamp()}`, gap: 20 },
      { text: `Objetivos seleccionados: ${[...selectedGoals].map(id => goals.find(goal=>goal.id===id)?.title).filter(Boolean).join(', ')}`, gap: 22 },
      { text: 'Estimación económica', size: 13, bold: true, gap: 18 }, { text: `Inversión inicial: ${fmt(edited.initial)}` }, { text: `Descuento del ${Math.round(t.rate * 100)} %: ${fmt(edited.discount)}` }, { text: `Total puntual: ${fmt(edited.totalOneTime)}` }, { text: `Servicios mensuales: ${fmt(edited.monthlyOwn)}` }, { text: `Servicios anuales: ${fmt(edited.annual)}` }, { text: `Honorarios publicitarios: ${fmt(t.items.filter(o=>o.id==='ads-gestion').reduce((a,o)=>a+(o.monthly||0),0))}` }, { text: `Presupuesto publicitario separado: ${fmt(edited.ad)}` }, { text: `Costes externos: ${fmt(edited.external)}`, gap: 22 },
      { text: 'Diseño y comunicación · Página web · Fotografía aérea con dron · 1.290 € · ¿Información sin IVA? ¡Sí!', gap: 20 },
      { text: 'Servicios seleccionados', size: 13, bold: true, gap: 18 },
      ...(t.items.length ? t.items.flatMap((item) => wrap(`- ${item.name}: ${item.pending ? 'Pendiente de valoración' : item.desc}`)) : ['- No se han seleccionado servicios.']).map((text) => ({ text })),
      { text: 'Servicios pendientes de valoración', size: 13, bold: true, gap: 18 },
      ...(t.items.filter((item) => item.pending).length ? t.items.filter((item) => item.pending).map((item) => `- ${item.name}: Pendiente de valoración`) : ['- No hay servicios pendientes.']).map((text) => ({ text })),
      { text: 'Condiciones comerciales', size: 13, bold: true, gap: 18 },
      ...wrap('Información sin IVA. Esta estimación no contractual puede variar según alcance, contenidos, materiales, proveedores, desplazamientos, tarifas externas y revisión técnica. No garantizamos posiciones en buscadores, visitas, contactos, ventas ni resultados publicitarios.').map((text)=>({ text })),
      ...wrap('Condiciones de pago: 50 % al aceptar, 30 % al aprobar la fase principal y 20 % antes de publicar o entregar. En trabajos pequeños puede solicitarse el pago completo al comenzar.').map((text)=>({ text })),
      ...wrap('Condiciones de trabajos con dron: sujetos a ubicación, normativa aplicable, seguridad, meteorología, restricciones del espacio aéreo, permisos y viabilidad técnica.').map((text)=>({ text })),
      { text: 'Datos de contacto de Flopitec', size: 13, bold: true, gap: 18 },
      { text: business.commercialName }, { text: business.address.full }, { text: `Teléfono: ${business.phone.main} · WhatsApp: ${business.whatsapp.label}` }, { text: `Correo: ${business.email} · ${business.address.locality}, ${business.address.province}` },
    ];
    const blob = buildPdf(blocks);
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a'); link.href = url; link.download = `estimacion-marketing-flopitec-${dateStamp()}.pdf`; link.click(); URL.revokeObjectURL(url);
  }
  document.getElementById('prevStep').addEventListener('click',()=>{current--;render();});
  document.getElementById('nextStep').addEventListener('click',()=>{const list=visibleSteps(); if(current < list.length-1) current++; render();});
  document.getElementById('resetEstimator').addEventListener('click',()=>{ if(confirm('¿Reiniciar la estimación y borrar los datos guardados?')){ sessionStorage.removeItem(storageKey); selectedGoals.clear(); selectedGoals.add('web'); selected.clear(); current = 0; render(); } });
  restoreState(); render();
</script>
