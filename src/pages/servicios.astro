---
import BaseLayout from '@/layouts/BaseLayout.astro'; import ServiceCard from '@/components/ServiceCard.astro'; import CTASection from '@/components/CTASection.astro'; import { servicePages } from '@/data/services';
---
<BaseLayout title="Servicios informáticos en La Zubia y Granada | Flopitec" description="Servicios de reparación, mantenimiento, empresas, marketing digital, venta y reciclaje electrónico." path="/servicios/"><section class="section"><div class="container"><p class="eyebrow">Servicios</p><h1 class="mt-3 text-4xl font-black">Servicios informáticos para particulares y empresas</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Revisamos cada caso, te explicamos las opciones con claridad y recomendamos únicamente lo que realmente necesitas.</p><div class="services-grid mt-8">{servicePages.map(service=><ServiceCard service={service}/>)}</div></div></section><CTASection title="¿Qué servicio necesitas?" text="Cuéntanos el problema y te orientamos sobre el siguiente paso sin compromiso ni promesas a distancia." /></BaseLayout>
