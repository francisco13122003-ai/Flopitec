---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CTASection from '@/components/CTASection.astro';
import { servicePages } from '@/data/services';

const serviceCategories = [
  {
    id: 'informatica-datos-empresas',
    title: 'Informática, datos y empresas',
    description:
      'Soluciones para ordenadores, software, almacenamiento, redes y necesidades informáticas de autónomos y empresas.',
    slugs: [
      'pc-portatiles',
      'software',
      'recuperacion-datos',
      'redes-wifi',
      'impresoras-perifericos',
      'soporte-empresas',
    ],
  },
  {
    id: 'dispositivos-electronica',
    title: 'Dispositivos y electrónica',
    description: 'Revisión y reparación de dispositivos de uso cotidiano y distintos equipos electrónicos.',
    slugs: ['moviles-tablets', 'consolas', 'televisores', 'robots-aspiradores', 'electronica'],
  },
  {
    id: 'telefonia-paqueteria',
    title: 'Telefonía y paquetería',
    description:
      'Gestiones de fibra y móvil, junto con los servicios disponibles en nuestro Punto InPost.',
    slugs: ['telefonia-internet', 'punto-inpost'],
  },
].map((category) => ({
  ...category,
  services: category.slugs
    .map((slug) => servicePages.find((service) => service.slug === slug))
    .filter(Boolean),
}));
---

<BaseLayout
  title="Reparación informática y electrónica en La Zubia | Flopitec"
  description="Reparación informática y electrónica para particulares, autónomos y empresas en el taller de La Zubia. Revisa todos los servicios de Flopitec desde 2001."
  path="/servicios/"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Servicios</p>
      <h1 class="mt-3 text-4xl font-black">Servicios de reparación informática y electrónica en La Zubia</h1>
      <p class="mt-4 max-w-3xl text-[var(--muted)]">
        Revisamos cada caso, te explicamos las opciones con claridad y recomendamos únicamente lo que realmente necesitas.
      </p>

      <div class="mt-10 grid gap-12">
        {
          serviceCategories.map((category) => (
            <section aria-labelledby={category.id} class="grid gap-5">
              <header>
                <h2 id={category.id} class="text-2xl font-black">
                  {category.title}
                </h2>
                <p class="mt-2 max-w-3xl text-[var(--muted)]">{category.description}</p>
              </header>

              <div class="services-grid">
                {category.services.map((service) => (
                  <ServiceCard service={service} />
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>
  <CTASection
    title="¿Qué servicio necesitas?"
    text="Cuéntanos el problema y te orientamos sobre el siguiente paso sin compromiso ni promesas a distancia."
  />
</BaseLayout>
