---
import BaseLayout from '@/layouts/BaseLayout.astro'; import ServiceCard from '@/components/ServiceCard.astro'; import CTASection from '@/components/CTASection.astro'; import { servicePages } from '@/data/services';
---
<BaseLayout title="Reparación informática y electrónica en La Zubia | Flopitec" description="Reparación informática y electrónica para particulares, autónomos y empresas en el taller de La Zubia. Revisa todos los servicios de Flopitec desde 2001." path="/servicios/"><section class="section"><div class="container"><p class="eyebrow">Servicios</p><h1 class="mt-3 text-4xl font-black">Servicios de reparación informática y electrónica en La Zubia</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Revisamos cada caso, te explicamos las opciones con claridad y recomendamos únicamente lo que realmente necesitas.</p><div class="services-grid mt-8">{servicePages.map(service=><ServiceCard service={service}/>)}</div></div></section><CTASection title="¿Qué servicio necesitas?" text="Cuéntanos el problema y te orientamos sobre el siguiente paso sin compromiso ni promesas a distancia." /></BaseLayout>
