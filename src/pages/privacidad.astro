---
import BaseLayout from '@/layouts/BaseLayout.astro'; import { business } from '@/data/business';
---
<BaseLayout title="Privacidad | Flopitec" description="Información básica de privacidad pendiente de revisión profesional." path="/privacidad/"><section class="section"><div class="container max-w-3xl"><h1 class="text-4xl font-black">Privacidad</h1><p class="mt-4 text-[var(--muted)]">Texto base pendiente de revisión profesional antes de publicación definitiva.</p><h2 class="mt-8 text-2xl font-black">Responsable</h2><p>{business.legalName} · NIF {business.nif}</p><p>{business.address.full}</p><p><a href={business.emailHref}>{business.email}</a></p><h2 class="mt-8 text-2xl font-black">Contacto</h2><p class="text-[var(--muted)]">Esta V1 no incluye formulario. Los enlaces de contacto abren teléfono, email, WhatsApp o mapas.</p></div></section></BaseLayout>
