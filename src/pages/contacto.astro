---
import BaseLayout from '@/layouts/BaseLayout.astro'; import ContactBlock from '@/components/ContactBlock.astro';
---
<BaseLayout title="Contacto | Flopitec Servicios Informáticos" description="Contacta con Flopitec por WhatsApp, teléfono, email o visita el taller en La Zubia, Granada." path="/contacto/"><section class="section"><div class="container"><p class="eyebrow">Contacto</p><h1 class="mt-3 text-4xl font-black">Hablemos de tu equipo</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Contacta con nosotros por WhatsApp, teléfono o email para consultar disponibilidad, horario o solicitar una revisión. También puedes encontrarnos fácilmente en Google Maps.</p></div></section><ContactBlock/></BaseLayout>
