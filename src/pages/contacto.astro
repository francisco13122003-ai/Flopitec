import BaseLayout from '@/layouts/BaseLayout.astro'; import ContactBlock from '@/components/ContactBlock.astro';
---
<BaseLayout title="Contacto Flopitec en La Zubia | Teléfono y WhatsApp" description="Contacta con Flopitec en La Zubia por teléfono, WhatsApp o email. Taller físico con atención a particulares, autónomos y empresas." path="/contacto/"><section class="section"><div class="container"><p class="eyebrow">Contacto</p><h1 class="mt-3 text-4xl font-black">Contactar con Flopitec en La Zubia</h1><p class="mt-4 max-w-3xl text-[var(--muted)]">Contacta con nosotros por WhatsApp, teléfono o email para consultar disponibilidad, horario o solicitar una revisión. También puedes encontrarnos fácilmente en Google Maps.</p></div></section><ContactBlock/></BaseLayout>
