---
import BaseLayout from '@/layouts/BaseLayout.astro'; import ContactBlock from '@/components/ContactBlock.astro';
---
<BaseLayout title="Contacto | Flopitec Servicios Informáticos" description="Contacta con Flopitec por WhatsApp, teléfono, email o visita el taller en La Zubia, Granada." path="/contacto/"><section class="section"><div class="container"><p class="eyebrow">Contacto</p><h1 class="mt-3 text-4xl font-black">Hablemos de tu equipo</h1><p class="mt-4 text-[var(--muted)]">No hay formulario en esta V1. Usa WhatsApp, teléfono, email o Google Maps.</p></div></section><ContactBlock/></BaseLayout>
