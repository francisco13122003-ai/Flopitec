import BaseLayout from '@/layouts/BaseLayout.astro'; import CTASection from '@/components/CTASection.astro';
---
<BaseLayout title="Sobre Flopitec | Servicio técnico local" description="Filosofía de Flopitec: diagnóstico claro, reparación realista y atención cercana en La Zubia." path="/sobre-nosotros/"><section class="section"><div class="container max-w-3xl"><p class="eyebrow">Sobre nosotros</p><h1 class="mt-3 text-4xl font-black">Servicio técnico local con trato directo</h1><p class="mt-5 text-[var(--muted)]">El cliente debe entender siempre qué le pasa a su equipo, por qué ocurre y qué opciones reales tiene. Reparamos, configuramos y asesoramos sin vender de más.</p><h2 class="mt-8 text-2xl font-black">Nuestra forma de trabajar</h2><p class="mt-3 text-[var(--muted)]">Cuidamos los equipos como si fueran nuestros, explicamos costes, plazos y posibilidades reales, y si algo no merece la pena lo decimos claramente.</p></div></section><CTASection/></BaseLayout>
