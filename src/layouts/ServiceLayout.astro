---
import BaseLayout from './BaseLayout.astro'; import Breadcrumbs from '@/components/Breadcrumbs.astro'; import CTASection from '@/components/CTASection.astro'; import { site } from '@/data/site';
const { service } = Astro.props; const path = `/servicios/${service.slug}/`;
const jsonLd = [{'@context':'https://schema.org','@type':'Service',name:service.title,description:service.short,areaServed:['La Zubia','Granada','Cájar','Ogíjares','Armilla','Huétor Vega','Monachil']},{'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:'Inicio',item:site.siteUrl+'/'},{'@type':'ListItem',position:2,name:'Servicios',item:site.siteUrl+'/servicios/'},{'@type':'ListItem',position:3,name:service.title,item:site.siteUrl+path}]}];
---
<BaseLayout title={`${service.title} | Flopitec`} description={service.short} path={path} jsonLd={jsonLd}><Breadcrumbs items={[{label:'Servicios',href:'/servicios/'},{label:service.title,href:path}]}/><article class="section"><div class="container grid gap-8 md:grid-cols-[1.2fr_.8fr]"><div><p class="eyebrow">{service.category}</p><h1 class="mt-3 text-4xl font-black">{service.title}</h1><p class="mt-5 text-lg text-[var(--muted)]">{service.short}</p><h2 class="mt-8 text-2xl font-black">Qué podemos revisar</h2><ul class="mt-4 grid gap-2">{service.items.map(item=><li>• {item}</li>)}</ul><h2 class="mt-8 text-2xl font-black">Cómo trabajamos</h2><p class="mt-3 text-[var(--muted)]">Explicamos el problema de forma sencilla, valoramos opciones reales y no recomendamos reparaciones que no compensan por valor del equipo, coste o uso previsto.</p></div><div class="placeholder" role="img" aria-label="Imagen real pendiente relacionada con el servicio"></div></div></article><CTASection/></BaseLayout>
