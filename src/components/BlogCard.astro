---
const { post } = Astro.props;
---
<article class="card p-6"><p class="eyebrow">Guía práctica</p><h2 class="mt-3 text-xl font-black"><a href={`/blog/${post.slug}/`}>{post.title}</a></h2><p class="mt-3 text-[var(--muted)]">{post.description}</p><a class="mt-5 inline-flex font-bold text-flopi-orange" href={`/blog/${post.slug}/`}>Leer artículo →</a></article>
