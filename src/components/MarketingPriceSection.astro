---
const { id, title, intro = [], groups = [], notices = [] } = Astro.props;
---
<section id={id} class="section anchored price-section">
  <div class="container">
    <h2 class="text-3xl font-black">{title}</h2>
    {intro.map((paragraph) => <p class="mt-4 max-w-3xl text-[var(--muted)]">{paragraph}</p>)}
    <div class="price-card-grid mt-8">
      {groups.map((group) => (
        <article class="card p-5">
          <h3 class="text-xl font-black">{group.title}</h3>
          <ul class="compact-list">
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
    {notices.length > 0 && <ul class="notice-list mt-6">{notices.map((notice) => <li>{notice}</li>)}</ul>}
  </div>
</section>
