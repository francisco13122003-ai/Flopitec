---
import { navigation } from '@/data/navigation';
import { business } from '@/data/business';
---
<header class="sticky top-0 z-40 border-b border-[var(--line)] bg-[color-mix(in_srgb,var(--surface)_88%,transparent)] backdrop-blur">
  <nav class="container flex items-center justify-between py-4" aria-label="Menú principal">
    <a href="/" class="font-black tracking-tight"><span class="text-flopi-orange">Flopi</span>tec</a>
    <div class="hidden gap-5 md:flex">{navigation.map((item)=><a class="text-sm font-semibold text-[var(--muted)] hover:text-[var(--ink)]" href={item.href}>{item.label}</a>)}</div>
    <a class="btn btn-primary !py-2" href={business.whatsapp.url}>WhatsApp</a>
  </nav>
</header>
