---
import { business } from '@/data/business';
const { title='¿Hablamos de tu equipo?', text='Cuéntanos qué ocurre por WhatsApp o ven al taller. Te orientamos con claridad antes de decidir.' } = Astro.props;
---
<section class="section"><div class="container card p-8 text-center"><h2 class="text-3xl font-black">{title}</h2><p class="mx-auto mt-3 max-w-2xl text-[var(--muted)]">{text}</p><div class="mt-6 flex justify-center gap-3"><a class="btn btn-primary" href={business.whatsapp.url}>WhatsApp</a><a class="btn" href="/contacto/">Contacto</a></div></div></section>
