---
import { business } from '@/data/business';
const { title, subtitle } = Astro.props;
---
<section class="section"><div class="container grid items-center gap-8 md:grid-cols-2"><div><p class="eyebrow">{business.slogan}</p><h1 class="mt-4 text-4xl font-black tracking-tight md:text-6xl">{title}</h1><p class="mt-5 text-lg text-[var(--muted)]">{subtitle}</p><div class="mt-7 flex flex-wrap gap-3"><a class="btn btn-primary" href={business.whatsapp.url}>Escribir por WhatsApp</a><a class="btn" href={business.phone.mainHref}>Llamar</a><a class="btn" href={business.mapsUrl}>Cómo llegar</a></div></div><img class="hero-image" src="/images/flopitec-equipo-reparando.webp" alt="Equipo de Flopitec reparando un dispositivo en el taller" width="720" height="450" loading="eager" decoding="async" fetchpriority="high" /></div></section>
