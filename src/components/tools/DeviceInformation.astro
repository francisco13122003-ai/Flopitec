<section class="card p-5 md:p-8" aria-labelledby="device-info-title">
  <h2 id="device-info-title" class="text-2xl font-black">Informe técnico disponible</h2>
  <p class="mt-2 text-[var(--muted)]">Al pulsar el botón se consultarán únicamente los datos técnicos que el navegador permita mostrar. No se solicitará acceso a archivos, cámara, micrófono ni ubicación.</p>
  <div class="mt-5 flex flex-wrap gap-3"><button id="device-analyze" class="btn btn-primary" type="button">Analizar este dispositivo</button><button id="device-copy" class="btn pointer-events-none opacity-50" type="button">Copiar informe</button><a id="device-download" class="btn pointer-events-none opacity-50" href="#" download>Descargar informe TXT</a><button id="device-reset" class="btn" type="button">Restablecer</button></div>
  <p class="mt-3 rounded-2xl border border-[var(--line)] p-4 text-sm text-[var(--muted)]">Revisa el informe antes de enviarlo. Puede contener datos técnicos sobre el sistema, el navegador y la tarjeta gráfica, pero no debería incluir contraseñas ni archivos personales.</p>
  <div id="device-status" class="mt-5 rounded-2xl border border-[var(--line)] p-4 text-sm text-[var(--muted)]" aria-live="polite">Pulsa el botón para generar el informe.</div>
  <div id="device-summary" class="mt-6 hidden rounded-2xl border border-[var(--accent)]/60 bg-orange-500/10 p-5"></div>
  <div id="device-report" class="mt-6 grid gap-5"></div>
</section>
<script>
const $=(id)=>document.getElementById(id), report=$('device-report'), status=$('device-status'), summary=$('device-summary'), copy=$('device-copy'), dl=$('device-download'); let txt='', url='';
const NA='No disponible en este navegador', NF='No facilitado por el navegador', AP='Valor aproximado'; const yes=(v)=>v?'Sí':'No'; const safe=(v)=>v===undefined||v===null||Number.isNaN(v)||v===Infinity?'':String(v); const bytes=(n)=>!Number.isFinite(n)?NF:n>1073741824?`${(n/1073741824).toFixed(2)} GB`:n>1048576?`${(n/1048576).toFixed(2)} MB`:`${(n/1024).toFixed(1)} KB`; const mins=(s)=>Number.isFinite(s)?(s>3600?`${(s/3600).toFixed(1)} horas`:`${Math.round(s/60)} minutos`):NF;
function setStatus(m,w=false){status.textContent=m; status.classList.toggle('text-red-200',w);} function revoke(){if(url) URL.revokeObjectURL(url); url='';} function enable(on){[copy,dl].forEach(e=>{e.classList.toggle('pointer-events-none',!on);e.classList.toggle('opacity-50',!on);});}
function section(title, rows, note=''){rows=rows.filter(r=>safe(r[1])); const art=document.createElement('article'); art.className='card p-5'; const h=document.createElement('h3'); h.className='text-xl font-black'; h.textContent=title; const dlEl=document.createElement('dl'); dlEl.className='mt-4 grid gap-3'; rows.forEach(([k,v])=>{const div=document.createElement('div'); div.className='grid gap-1 border-b border-[var(--line)] pb-3 sm:grid-cols-[14rem_1fr]'; const dt=document.createElement('dt'); dt.className='font-bold'; dt.textContent=k; const dd=document.createElement('dd'); dd.className='text-[var(--muted)] [overflow-wrap:anywhere]'; dd.textContent=safe(v); div.append(dt,dd); dlEl.append(div);}); art.append(h,dlEl); if(note){const p=document.createElement('p'); p.className='mt-4 text-sm text-[var(--muted)]'; p.textContent=note; art.append(p);} report.append(art); return {title,rows,note};}
async function permissions(){const names=['camera','microphone','geolocation','notifications','clipboard-read','clipboard-write','persistent-storage']; const map={granted:'Concedido',denied:'Denegado',prompt:'Preguntará al utilizarse'}; const out=[]; for(const name of names){try{if(!navigator.permissions) out.push([name,'No compatible con este navegador']); else {const r=await navigator.permissions.query({name}); out.push([name,map[r.state]||NF]);}}catch{out.push([name,'No compatible con este navegador']);}} return out;}
function glInfo(){const canvas=document.createElement('canvas'); let gl=canvas.getContext('webgl2')||canvas.getContext('webgl'); const rows=[['Soporte WebGL',yes(Boolean(canvas.getContext('webgl')))],['Soporte WebGL 2',yes(Boolean(canvas.getContext('webgl2')))]]; if(gl){rows.push(['Proveedor WebGL',gl.getParameter(gl.VENDOR)],['GPU o renderizador expuesto por el navegador',gl.getParameter(gl.RENDERER)],['Versión WebGL',gl.getParameter(gl.VERSION)],['Versión GLSL',gl.getParameter(gl.SHADING_LANGUAGE_VERSION)],['Tamaño máximo de textura',gl.getParameter(gl.MAX_TEXTURE_SIZE)]); try{const ext=gl.getExtension('WEBGL_debug_renderer_info'); if(ext) rows.push(['Proveedor WebGL sin enmascarar',gl.getParameter(ext.UNMASKED_VENDOR_WEBGL)],['Renderizador WebGL sin enmascarar',gl.getParameter(ext.UNMASKED_RENDERER_WEBGL)]);}catch{} try{gl.getExtension('WEBGL_lose_context')?.loseContext();}catch{}} return rows;}
async function gpuRows(){const rows=[['Soporte WebGPU',yes('gpu' in navigator)],['Información WebGPU expuesta',NA]]; try{if('gpu' in navigator){const a=await navigator.gpu.requestAdapter(); if(a){const info=a.info||{}; rows[1][1]=[info.vendor,info.architecture,info.device,info.description].filter(Boolean).join(' · ')||NF; rows.push(['Proveedor WebGPU',info.vendor||NF],['Arquitectura WebGPU',info.architecture||NF],['Descripción WebGPU',info.description||NF],['Adaptador de respaldo',safe(info.isFallbackAdapter)||NF]);}}}catch{rows.push(['WebGPU',NF]);} return rows;}
async function analyze(){revoke(); report.replaceChildren(); summary.classList.add('hidden'); enable(false); setStatus('Analizando información disponible…'); const made=[]; const now=new Date(); try{const ua=navigator.userAgentData; let high={}; try{high=ua?.getHighEntropyValues?await ua.getHighEntropyValues(['architecture','bitness','formFactors','fullVersionList','model','platformVersion','wow64']):{};}catch{} made.push(section('Sistema y navegador', [['Navegador o marcas expuestas',ua?.brands?.map(b=>`${b.brand} ${b.version}`).join(', ')||NF],['Versiones expuestas',high.fullVersionList?.map(b=>`${b.brand} ${b.version}`).join(', ')||NF],['Plataforma',ua?.platform||navigator.platform||NF],['Versión de plataforma',high.platformVersion||NF],['Arquitectura',high.architecture||NF],['Número de bits',high.bitness||NF],['Modelo del dispositivo',high.model||NF],['Indicador móvil',ua?yes(ua.mobile):NF],['Indicador WOW64',high.wow64===undefined?NF:yes(high.wow64)],['Factores de forma',high.formFactors?.join(', ')||NF],['User agent técnico de respaldo',navigator.userAgent||NF],['Idioma principal',navigator.language||NF],['Lista de idiomas',navigator.languages?.join(', ')||NF],['Zona horaria',Intl.DateTimeFormat().resolvedOptions().timeZone||NF],['Fecha y hora local en el momento del informe',now.toLocaleString()],['Contexto HTTPS seguro',yes(window.isSecureContext)],['Conexión online',yes(navigator.onLine)],['Cookies habilitadas',yes(navigator.cookieEnabled)],['Do Not Track',navigator.doNotTrack||NF],['Visor PDF expuesto',navigator.pdfViewerEnabled===undefined?NF:yes(navigator.pdfViewerEnabled)]]));
 made.push(section('Procesamiento y memoria', [['Procesadores lógicos disponibles',navigator.hardwareConcurrency?`${navigator.hardwareConcurrency} (${AP})`:NF],['Memoria aproximada expuesta por el navegador',navigator.deviceMemory?`${navigator.deviceMemory} GB (${AP})`:NA],['SharedArrayBuffer','SharedArrayBuffer' in window?yes(true):yes(false)],['crossOriginIsolated',yes(window.crossOriginIsolated)],['WebAssembly',yes('WebAssembly' in window)]], 'El navegador puede reducir u ocultar estos valores para proteger la privacidad.'));
 made.push(section('Gráficos', [...glInfo(), ...(await gpuRows())], 'El navegador puede mostrar un nombre genérico, ocultar el modelo o utilizar una capa de traducción gráfica.'));
 const mq=(q)=>matchMedia(q).matches; made.push(section('Pantalla y visualización', [['Resolución de pantalla',`${screen.width} × ${screen.height}`],['Espacio disponible de pantalla',`${screen.availWidth} × ${screen.availHeight}`],['Tamaño actual del viewport',`${innerWidth} × ${innerHeight}`],['Densidad de píxeles',devicePixelRatio],['Profundidad de color',screen.colorDepth],['Profundidad de píxel',screen.pixelDepth],['Orientación',screen.orientation?.type||NF],['Ángulo de orientación',screen.orientation?.angle??NF],['Máximo número de puntos táctiles',navigator.maxTouchPoints??NF],['Pantalla táctil aproximada',yes((navigator.maxTouchPoints||0)>0||mq('(pointer: coarse)'))],['Varias pantallas',screen.isExtended===undefined?NA:yes(screen.isExtended)],['Tema oscuro preferido',yes(mq('(prefers-color-scheme: dark)'))],['Tema claro preferido',yes(mq('(prefers-color-scheme: light)'))],['Movimiento reducido',yes(mq('(prefers-reduced-motion: reduce)'))],['Contraste aumentado',yes(mq('(prefers-contrast: more)'))],['Contraste reducido',yes(mq('(prefers-contrast: less)'))],['Colores forzados',yes(mq('(forced-colors: active)'))],['Puntero principal',mq('(pointer: coarse)')?'Grueso':mq('(pointer: fine)')?'Fino':NF],['Hover disponible',yes(mq('(hover: hover)'))],['Modo de aplicación instalada',yes(mq('(display-mode: standalone)'))]]));
 const c=navigator.connection||navigator.mozConnection||navigator.webkitConnection; made.push(section('Conexión', [['Estado online',yes(navigator.onLine)],['Tipo de conexión expuesto',c?.type||NA],['Tipo efectivo',c?.effectiveType||NA],['Velocidad estimada por el navegador',c?.downlink?`${c.downlink} Mbps (${AP})`:NA],['Latencia estimada por el navegador',c?.rtt?`${c.rtt} ms (${AP})`:NA],['Ahorro de datos',c?.saveData===undefined?NA:yes(c.saveData)]], 'Estos valores son estimaciones del navegador y no constituyen una prueba de velocidad.'));
 let st=[['Espacio utilizado por este sitio',NA],['Cuota estimada para este sitio',NA],['Porcentaje aproximado utilizado',NA]]; try{const e=await navigator.storage?.estimate?.(); if(e){st=[['Espacio utilizado por este sitio',bytes(e.usage)],['Cuota estimada para este sitio',bytes(e.quota)],['Porcentaje aproximado utilizado',e.quota?`${((e.usage/e.quota)*100).toFixed(2)}%`:NF],['Detalle por sistema de almacenamiento',e.usageDetails?Object.entries(e.usageDetails).map(([k,v])=>`${k}: ${bytes(v)}`).join(', '):NF]]}}catch{} made.push(section('Almacenamiento del navegador', st, 'Esta cifra corresponde al almacenamiento que el navegador asigna a este sitio. No representa la capacidad total ni el espacio libre real del disco.'));
 let bat=[['Batería','Información de batería no disponible en este navegador.']]; try{if(navigator.getBattery){const b=await navigator.getBattery(); bat=[['Nivel actual',`${Math.round(b.level*100)}%`],['Cargando',yes(b.charging)],['Tiempo estimado hasta carga completa',mins(b.chargingTime)],['Tiempo estimado de descarga',mins(b.dischargingTime)]];}}catch{} made.push(section('Batería',bat));
 made.push(section('Capacidades del navegador', [['JavaScript','Sí'],['WebAssembly',yes('WebAssembly' in window)],['WebGL',yes(glInfo()[0][1]==='Sí')],['WebGL 2',yes(glInfo()[1][1]==='Sí')],['WebGPU',yes('gpu' in navigator)],['Service Worker',yes('serviceWorker' in navigator)],['WebRTC',yes('RTCPeerConnection' in window)],['IndexedDB',yes('indexedDB' in window)],['API de portapapeles',yes('clipboard' in navigator)],['API de notificaciones',yes('Notification' in window)],['API de pantalla completa',yes('fullscreenEnabled' in document)],['API de dispositivos multimedia',yes('mediaDevices' in navigator)],['API de archivos',yes('FileReader' in window)],['File System Access API',yes('showSaveFilePicker' in window)],['Compartir mediante Web Share',yes('share' in navigator)],['Soporte táctil',yes((navigator.maxTouchPoints||0)>0)],['Cookies habilitadas',yes(navigator.cookieEnabled)],['Almacenamiento web expuesto',yes('Storage' in window)],['Contexto seguro HTTPS',yes(window.isSecureContext)]]));
 made.push(section('Estado de permisos', await permissions(), 'Esta sección muestra el estado que el navegador facilita; no comprueba que el dispositivo físico exista o funcione correctamente.'));
 txt=['INFORME TÉCNICO DEL DISPOSITIVO','Generado desde Flopitec',`Fecha: ${now.toLocaleString()}`,'',...made.flatMap(s=>[s.title.toUpperCase(),...s.rows.map(([k,v])=>`${k}: ${safe(v)}`),s.note,'']), 'Este informe contiene únicamente la información que el navegador ha permitido consultar. Algunos valores son aproximados o pueden estar ocultos.'].join('\n'); url=URL.createObjectURL(new Blob([txt],{type:'text/plain;charset=utf-8'})); const pad=(n)=>String(n).padStart(2,'0'); dl.href=url; dl.download=`informe-dispositivo-flopitec-${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}-${pad(now.getHours())}${pad(now.getMinutes())}.txt`; summary.textContent='Resumen principal: informe generado con secciones de sistema, procesamiento, gráficos, pantalla, conexión, almacenamiento del sitio, batería, capacidades y permisos.'; summary.classList.remove('hidden'); enable(true); setStatus('Informe generado.');}catch(e){setStatus('No se ha podido completar parte del análisis.',true);}}
$('device-analyze').addEventListener('click',analyze); $('device-reset').addEventListener('click',()=>{revoke(); txt=''; report.replaceChildren(); summary.classList.add('hidden'); enable(false); setStatus('Pulsa el botón para generar el informe.');}); copy.addEventListener('click',async()=>{try{if(navigator.clipboard) await navigator.clipboard.writeText(txt); else {const ta=document.createElement('textarea'); ta.value=txt; document.body.append(ta); ta.select(); document.execCommand('copy'); ta.remove();} setStatus('Informe copiado.');}catch{setStatus('No se ha podido copiar automáticamente.',true);}}); window.addEventListener('beforeunload',revoke); enable(false);
</script>
