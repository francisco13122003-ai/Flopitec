<section class="card p-5 md:p-8" aria-labelledby="image-converter-title">
  <h2 id="image-converter-title" class="text-2xl font-black">Convertir una imagen</h2>
  <p class="mt-2 text-[var(--muted)]">Selecciona una imagen JPG, PNG o WebP. El archivo se procesa en tu dispositivo y no se envía a los servidores de Flopitec.</p>

  <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_1fr]">
    <div class="grid gap-5">
      <div>
        <label for="image-file" class="block font-bold">Seleccionar imagen</label>
        <input id="image-file" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3 file:mr-4 file:rounded-full file:border-0 file:bg-[var(--accent)] file:px-4 file:py-2 file:font-bold file:text-black" type="file" accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp" />
        <p class="mt-2 text-sm text-[var(--muted)]">Formatos admitidos: JPG, PNG y WebP.</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="output-format" class="block font-bold">Formato de salida</label>
          <select id="output-format" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3">
            <option value="image/jpeg">JPG</option>
            <option value="image/png">PNG</option>
            <option value="image/webp" selected>WebP</option>
          </select>
        </div>
        <div>
          <label for="quality" class="block font-bold">Calidad: <span id="quality-value">85</span></label>
          <input id="quality" class="mt-3 w-full accent-[var(--accent)] disabled:opacity-50" type="range" min="10" max="100" value="85" />
          <p id="quality-help" class="mt-2 text-sm text-[var(--muted)]">Disponible para JPG y WebP.</p>
        </div>
      </div>

      <fieldset class="grid gap-4 sm:grid-cols-2">
        <legend class="font-bold">Dimensiones</legend>
        <div>
          <label for="width" class="block text-sm font-bold">Ancho en píxeles</label>
          <input id="width" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" type="number" min="1" max="12000" inputmode="numeric" />
        </div>
        <div>
          <label for="height" class="block text-sm font-bold">Alto en píxeles</label>
          <input id="height" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" type="number" min="1" max="12000" inputmode="numeric" />
        </div>
        <label class="flex items-center gap-3 sm:col-span-2"><input id="keep-ratio" class="h-5 w-5 accent-[var(--accent)]" type="checkbox" checked /> Mantener proporción</label>
      </fieldset>

      <dl id="original-info" class="hidden rounded-2xl border border-[var(--line)] p-4 text-sm"></dl>
      <div id="status" class="rounded-2xl border border-[var(--line)] p-4 text-sm text-[var(--muted)]" aria-live="polite">Selecciona una imagen JPG, PNG o WebP válida.</div>

      <div class="flex flex-wrap gap-3">
        <button id="convert-button" class="btn btn-primary disabled:cursor-not-allowed disabled:opacity-50" type="button" disabled>Convertir imagen</button>
        <a id="download-link" class="btn pointer-events-none opacity-50" href="#" download>Descargar imagen</a>
        <button id="reset-button" class="btn" type="button">Restablecer</button>
      </div>
    </div>

    <div class="grid gap-5">
      <figure class="rounded-2xl border border-[var(--line)] p-4">
        <figcaption class="font-bold">Vista previa original</figcaption>
        <img id="original-preview" class="mt-3 hidden max-h-72 w-full rounded-xl object-contain" alt="Vista previa de la imagen original seleccionada" />
      </figure>
      <figure class="rounded-2xl border border-[var(--line)] p-4">
        <figcaption class="font-bold">Vista previa del resultado</figcaption>
        <img id="result-preview" class="mt-3 hidden max-h-72 w-full rounded-xl object-contain" alt="Vista previa de la imagen convertida" />
        <dl id="result-info" class="mt-4 hidden text-sm"></dl>
      </figure>
    </div>
  </div>
</section>

<script>
  const MAX_FILE_SIZE = 25 * 1024 * 1024;
  const MAX_DIMENSION = 12000;
  const MAX_OUTPUT_PIXELS = 40_000_000;
  const extByMime = { 'image/jpeg': 'jpg', 'image/png': 'png', 'image/webp': 'webp' };
  const input = document.getElementById('image-file');
  const format = document.getElementById('output-format');
  const quality = document.getElementById('quality');
  const qualityValue = document.getElementById('quality-value');
  const qualityHelp = document.getElementById('quality-help');
  const width = document.getElementById('width');
  const height = document.getElementById('height');
  const keepRatio = document.getElementById('keep-ratio');
  const status = document.getElementById('status');
  const originalInfo = document.getElementById('original-info');
  const resultInfo = document.getElementById('result-info');
  const originalPreview = document.getElementById('original-preview');
  const resultPreview = document.getElementById('result-preview');
  const convertButton = document.getElementById('convert-button');
  const downloadLink = document.getElementById('download-link');
  const resetButton = document.getElementById('reset-button');
  let originalUrl = '', resultUrl = '', currentFile = null, image = null, ratio = 1, syncing = false, converting = false;
  const size = (bytes) => bytes >= 1024 * 1024 ? `${(bytes / 1024 / 1024).toFixed(2)} MB` : `${(bytes / 1024).toFixed(1)} KB`;
  const setStatus = (message, error = false) => { status.textContent = message; status.classList.toggle('text-red-200', error); status.classList.toggle('text-[var(--muted)]', !error); };
  const revoke = (kind) => { if ((kind === 'original' || kind === 'all') && originalUrl) URL.revokeObjectURL(originalUrl), originalUrl = ''; if ((kind === 'result' || kind === 'all') && resultUrl) URL.revokeObjectURL(resultUrl), resultUrl = ''; };
  const setDownload = (enabled, name = '') => { downloadLink.classList.toggle('pointer-events-none', !enabled); downloadLink.classList.toggle('opacity-50', !enabled); if (enabled) downloadLink.download = name; else downloadLink.removeAttribute('download'); };
  const resetResult = () => { revoke('result'); resultPreview.removeAttribute('src'); resultPreview.classList.add('hidden'); resultInfo.classList.add('hidden'); resultInfo.innerHTML = ''; setDownload(false); };
  const updateQuality = () => { qualityValue.textContent = quality.value; const png = format.value === 'image/png'; quality.disabled = png; qualityHelp.textContent = png ? 'PNG no utiliza este ajuste de calidad.' : 'Disponible para JPG y WebP.'; };
  const validDims = () => { const w = Number(width.value), h = Number(height.value); if (!Number.isInteger(w) || !Number.isInteger(h) || w <= 0 || h <= 0) return null; if (w > MAX_DIMENSION || h > MAX_DIMENSION) return null; if (w * h > MAX_OUTPUT_PIXELS) return null; return { w, h }; };
  const baseName = (name) => (name.replace(/\.[^/.]+$/, '').trim() || 'imagen');
  const renderInfo = (el, rows) => {
    el.replaceChildren();
    rows.forEach(([key, value]) => {
      const row = document.createElement('div');
      const term = document.createElement('dt');
      const detail = document.createElement('dd');
      row.className = 'grid grid-cols-[9rem_1fr] gap-2 py-1';
      term.className = 'font-bold';
      detail.className = 'text-[var(--muted)]';
      term.textContent = key;
      detail.textContent = value;
      row.append(term, detail);
      el.append(row);
    });
    el.classList.remove('hidden');
  };
  const loadImage = (url) => new Promise((resolve, reject) => { const img = new Image(); img.onload = async () => { try { if (img.decode) await img.decode(); resolve(img); } catch (e) { reject(e); } }; img.onerror = reject; img.src = url; });
  input.addEventListener('change', async () => {
    resetResult(); revoke('original'); image = null; currentFile = input.files && input.files[0]; convertButton.disabled = true; originalInfo.classList.add('hidden'); originalPreview.classList.add('hidden');
    if (!currentFile || !['image/jpeg','image/png','image/webp'].includes(currentFile.type)) return setStatus('Selecciona una imagen JPG, PNG o WebP válida.', true);
    if (currentFile.size > MAX_FILE_SIZE) return setStatus('La imagen supera el límite de 25 MB.', true);
    originalUrl = URL.createObjectURL(currentFile);
    try {
      image = await loadImage(originalUrl); ratio = image.naturalWidth / image.naturalHeight; width.value = image.naturalWidth; height.value = image.naturalHeight;
      originalPreview.src = originalUrl; originalPreview.classList.remove('hidden');
      renderInfo(originalInfo, [['Nombre', currentFile.name], ['Formato', currentFile.type], ['Dimensiones', `${image.naturalWidth} × ${image.naturalHeight} px`], ['Tamaño', size(currentFile.size)]]);
      convertButton.disabled = false; setStatus('Imagen cargada. Ajusta las opciones y convierte el archivo.');
    } catch (error) { console.error(error); revoke('original'); setStatus('No se ha podido abrir la imagen.', true); }
  });
  width.addEventListener('input', () => { if (!keepRatio.checked || syncing || !ratio) return; const w = Number(width.value); if (w > 0) { syncing = true; height.value = Math.max(1, Math.round(w / ratio)); syncing = false; } });
  height.addEventListener('input', () => { if (!keepRatio.checked || syncing || !ratio) return; const h = Number(height.value); if (h > 0) { syncing = true; width.value = Math.max(1, Math.round(h * ratio)); syncing = false; } });
  quality.addEventListener('input', updateQuality); format.addEventListener('change', () => { updateQuality(); resetResult(); });
  convertButton.addEventListener('click', async () => {
    if (converting || !image || !currentFile) return; const dims = validDims();
    if (!dims) return setStatus('Introduce unas dimensiones válidas. La imagen resultante sería demasiado grande.', true);
    converting = true; convertButton.disabled = true; convertButton.textContent = 'Convirtiendo…'; resetResult(); setStatus('Convirtiendo…');
    try {
      const canvas = document.createElement('canvas'); canvas.width = dims.w; canvas.height = dims.h; const ctx = canvas.getContext('2d'); if (!ctx) throw new Error('canvas');
      if (format.value === 'image/jpeg') { ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, dims.w, dims.h); }
      ctx.drawImage(image, 0, 0, dims.w, dims.h);
      const blob = await new Promise((resolve) => canvas.toBlob(resolve, format.value, Number(quality.value) / 100));
      if (!blob) throw new Error('blob');
      if (blob.type !== format.value) return setStatus('Tu navegador no permite exportar al formato seleccionado.', true);
      resultUrl = URL.createObjectURL(blob); resultPreview.src = resultUrl; resultPreview.classList.remove('hidden');
      const diff = currentFile.size ? `${(((blob.size - currentFile.size) / currentFile.size) * 100).toFixed(1)}%` : 'No disponible';
      renderInfo(resultInfo, [['Formato', blob.type], ['Dimensiones', `${dims.w} × ${dims.h} px`], ['Tamaño final', size(blob.size)], ['Diferencia', diff]]);
      setDownload(true, `${baseName(currentFile.name)}-convertida.${extByMime[blob.type]}`); setStatus('Conversión terminada. Puedes descargar la imagen.');
    } catch (error) { console.error(error); setStatus('No se ha podido generar el archivo convertido.', true); }
    finally { converting = false; convertButton.disabled = !image; convertButton.textContent = 'Convertir imagen'; }
  });
  resetButton.addEventListener('click', () => { input.value = ''; width.value = ''; height.value = ''; keepRatio.checked = true; format.value = 'image/webp'; quality.value = '85'; updateQuality(); currentFile = null; image = null; convertButton.disabled = true; originalInfo.classList.add('hidden'); originalPreview.removeAttribute('src'); originalPreview.classList.add('hidden'); resetResult(); revoke('all'); setStatus('Selecciona una imagen JPG, PNG o WebP válida.'); });
  window.addEventListener('beforeunload', () => revoke('all'));
  updateQuality();
</script>
