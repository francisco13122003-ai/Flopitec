<section class="card p-5 md:p-8" aria-labelledby="qr-generator-title">
  <h2 id="qr-generator-title" class="text-2xl font-black">Crear código QR</h2>
  <p class="mt-2 text-[var(--muted)]">Todo se genera localmente en el navegador, sin formularios enviados ni servicios externos.</p>
  <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_24rem]">
    <div class="grid gap-5">
      <div><label class="block font-bold" for="qr-type">Tipo de contenido</label><select id="qr-type" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3"><option value="url">Dirección web</option><option value="text">Texto</option><option value="wifi">Red Wi-Fi</option><option value="phone">Teléfono</option><option value="email">Correo electrónico</option><option value="whatsapp">WhatsApp</option></select></div>
      <div id="group-url" class="qr-group"><label for="qr-url" class="block font-bold">Dirección web</label><input id="qr-url" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" maxlength="2048" inputmode="url" aria-describedby="qr-url-error" /><p class="mt-2 text-sm text-[var(--muted)]">Debe comenzar por https:// o http://.</p><p id="qr-url-error" class="mt-2 text-sm font-bold text-red-200"></p></div>
      <div id="group-text" class="qr-group hidden"><label for="qr-text" class="block font-bold">Texto</label><textarea id="qr-text" class="mt-2 min-h-36 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" maxlength="2000"></textarea><p class="mt-2 text-sm text-[var(--muted)]"><span id="qr-text-count">0</span>/2000 caracteres.</p></div>
      <fieldset id="group-wifi" class="qr-group hidden grid gap-4"><legend class="font-bold">Red Wi-Fi</legend><p class="rounded-2xl border border-[var(--accent)]/60 bg-orange-500/10 p-4 text-sm font-bold">El código QR contiene los datos de acceso introducidos. No lo publiques ni lo compartas con personas que no deban conectarse a la red.</p><div><label class="block font-bold" for="wifi-ssid">Nombre de la red</label><input id="wifi-ssid" maxlength="64" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" /></div><div><label class="block font-bold" for="wifi-security">Tipo de seguridad</label><select id="wifi-security" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3"><option value="WPA">WPA/WPA2/WPA3</option><option value="WEP">WEP</option><option value="nopass">Sin contraseña</option></select></div><div id="wifi-pass-wrap"><label class="block font-bold" for="wifi-pass">Contraseña</label><div class="mt-2 flex gap-2"><input id="wifi-pass" type="password" maxlength="128" class="min-w-0 flex-1 rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" /><button id="toggle-pass" class="btn" type="button">Mostrar contraseña</button></div></div><label class="flex items-center gap-3"><input id="wifi-hidden" class="h-5 w-5 accent-[var(--accent)]" type="checkbox" /> Red oculta</label></fieldset>
      <div id="group-phone" class="qr-group hidden"><label for="qr-phone" class="block font-bold">Número de teléfono</label><input id="qr-phone" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" inputmode="tel" /></div>
      <fieldset id="group-email" class="qr-group hidden grid gap-4"><legend class="font-bold">Correo electrónico</legend><div><label for="email-address" class="block font-bold">Correo electrónico</label><input id="email-address" type="email" maxlength="254" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" /></div><div><label for="email-subject" class="block font-bold">Asunto opcional</label><input id="email-subject" maxlength="150" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" /></div><div><label for="email-body" class="block font-bold">Mensaje opcional</label><textarea id="email-body" maxlength="1000" class="mt-2 min-h-28 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3"></textarea></div></fieldset>
      <fieldset id="group-whatsapp" class="qr-group hidden grid gap-4"><legend class="font-bold">WhatsApp</legend><div><label for="wa-phone" class="block font-bold">Número con prefijo internacional</label><input id="wa-phone" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3" inputmode="tel" /><p class="mt-2 text-sm text-[var(--muted)]">Incluye el prefijo internacional, por ejemplo 34 para España.</p></div><div><label for="wa-text" class="block font-bold">Mensaje opcional</label><textarea id="wa-text" maxlength="1000" class="mt-2 min-h-28 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3"></textarea></div></fieldset>
      <fieldset class="grid gap-4 sm:grid-cols-2"><legend class="font-bold sm:col-span-2">Opciones QR</legend><div><label for="qr-correction" class="block font-bold">Corrección de errores</label><select id="qr-correction" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3"><option value="L">L — baja</option><option selected value="M">M — media</option><option value="Q">Q — alta</option><option value="H">H — muy alta</option></select><p class="mt-2 text-sm text-[var(--muted)]">Una corrección mayor puede facilitar la lectura si el código sufre pequeños daños, pero también aumenta su densidad.</p></div><div><label for="qr-size" class="block font-bold">Tamaño PNG</label><select id="qr-size" class="mt-2 w-full rounded-2xl border border-[var(--line)] bg-[var(--soft)] p-3"><option value="512">512 × 512</option><option selected value="1024">1024 × 1024</option></select></div></fieldset>
      <div id="qr-status" class="rounded-2xl border border-[var(--line)] p-4 text-sm text-[var(--muted)]" aria-live="polite">Completa los datos para generar el código.</div>
      <div class="flex flex-wrap gap-3"><button id="qr-generate" class="btn btn-primary" type="button">Generar código QR</button><a id="qr-png" class="btn pointer-events-none opacity-50" href="#" download="codigo-qr-flopitec.png">Descargar PNG</a><a id="qr-svg" class="btn pointer-events-none opacity-50" href="#" download="codigo-qr-flopitec.svg">Descargar SVG</a><button id="qr-copy" class="btn" type="button">Copiar contenido</button><button id="qr-reset" class="btn" type="button">Restablecer</button></div>
    </div>
    <figure id="qr-preview-card" class="hidden rounded-2xl border border-[var(--line)] p-4"><figcaption class="font-bold">Vista previa del código QR</figcaption><p class="mt-2 text-sm text-[var(--muted)]">Imagen cuadrada en blanco y negro con margen claro.</p><canvas id="qr-canvas" class="mt-4 aspect-square max-w-full rounded-xl bg-white p-2 [image-rendering:pixelated]" width="1024" height="1024"></canvas><h3 class="mt-5 font-bold">Contenido codificado</h3><pre id="qr-content" class="mt-2 whitespace-pre-wrap rounded-xl bg-[var(--soft)] p-3 text-sm text-[var(--muted)] [overflow-wrap:anywhere]"></pre></figure>
  </div>
</section>
<script>
import qrcode from 'qrcode-generator';
const $=(id)=>document.getElementById(id); const type=$('qr-type'), status=$('qr-status'), canvas=$('qr-canvas'), content=$('qr-content'), card=$('qr-preview-card'), png=$('qr-png'), svg=$('qr-svg'); let pngUrl='', svgUrl='', last='';
const groups=[...document.querySelectorAll('.qr-group')]; const setStatus=(m,e=false)=>{status.textContent=m;status.classList.toggle('text-red-200',e);}; const normPhone=(v)=>v.replace(/[\s().-]/g,''); const digits=(v)=>v.replace(/\D/g,''); const wifiEsc=(v)=>v.replace(/[\\;,:"]/g,'\\$&'); const emailOk=(v)=>v.length<=254&&v.includes('@')&&v.split('@')[0]&&v.split('@')[1]?.includes('.');
function revoke(){ if(pngUrl) URL.revokeObjectURL(pngUrl); if(svgUrl) URL.revokeObjectURL(svgUrl); pngUrl=''; svgUrl=''; }
function setDownloads(on){ [png,svg].forEach(a=>{a.classList.toggle('pointer-events-none',!on);a.classList.toggle('opacity-50',!on);}); if(!on){png.removeAttribute('href');svg.removeAttribute('href');}}
function active(){ groups.forEach(g=>g.classList.toggle('hidden',g.id!==`group-${type.value}`)); $('wifi-pass-wrap').classList.toggle('hidden',$('wifi-security').value==='nopass'); }
function payload(){ const t=type.value; if(t==='url'){const v=$('qr-url').value.trim(); if(!v) throw Error('empty'); let u; try{u=new URL(v);}catch{return void(function(){throw Error('url')})()} if(!['http:','https:'].includes(u.protocol)) throw Error('url'); return [u.toString(),u.toString()];}
 if(t==='text'){const v=$('qr-text').value; if(!v.trim()) throw Error('empty'); return [v,v];}
 if(t==='wifi'){const s=$('wifi-ssid').value; const sec=$('wifi-security').value; const p=$('wifi-pass').value; if(!s.trim()) throw Error('empty'); if(sec!=='nopass'&&!p) throw Error('empty'); const raw=`WIFI:T:${sec};S:${wifiEsc(s)};P:${sec==='nopass'?'':wifiEsc(p)};H:${$('wifi-hidden').checked?'true':'false'};;`; return [raw,`Red Wi-Fi: ${s} — ${sec==='nopass'?'sin contraseña':'contraseña incluida en el QR'}`];}
 if(t==='phone'){const n=normPhone($('qr-phone').value); const d=digits(n); if(d.length<6||d.length>15||!/^[+\d][\d+]*$/.test(n)) throw Error('phone'); return [`tel:${n}`,`tel:${n}`];}
 if(t==='email'){const e=$('email-address').value.trim(); if(!emailOk(e)) throw Error('email'); const params=new URLSearchParams(); if($('email-subject').value) params.set('subject',$('email-subject').value); if($('email-body').value) params.set('body',$('email-body').value); return [`mailto:${encodeURIComponent(e)}${params.toString()?`?${params}`:''}`,`mailto:${e}${params.toString()?`?${params}`:''}`];}
 const n=digits($('wa-phone').value); if(n.length<8||n.length>15) throw Error('phone'); const msg=$('wa-text').value; return [`https://wa.me/${n}${msg?`?text=${encodeURIComponent(msg)}`:''}`,`https://wa.me/${n}${msg?`?text=${msg}`:''}`]; }
function draw(qr){ const n=qr.getModuleCount(), margin=4, size=Number($('qr-size').value), cell=Math.floor(size/(n+margin*2)), real=cell*(n+margin*2); canvas.width=real; canvas.height=real; const ctx=canvas.getContext('2d'); ctx.imageSmoothingEnabled=false; ctx.fillStyle='#fff'; ctx.fillRect(0,0,real,real); ctx.fillStyle='#000'; for(let r=0;r<n;r++)for(let c=0;c<n;c++)if(qr.isDark(r,c))ctx.fillRect((c+margin)*cell,(r+margin)*cell,cell,cell); return {n,margin};}
function makeSvg(qr,n,margin){let rects=''; for(let r=0;r<n;r++)for(let c=0;c<n;c++)if(qr.isDark(r,c))rects+=`<rect x="${c+margin}" y="${r+margin}" width="1" height="1"/>`; const size=n+margin*2; return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${size} ${size}" shape-rendering="crispEdges"><rect width="100%" height="100%" fill="#fff"/><g fill="#000">${rects}</g></svg>`;}
$('qr-generate').addEventListener('click',async()=>{revoke();setDownloads(false);setStatus('Generando código…');try{const [data,label]=payload(); if(data.length>2953) throw Error('long'); const qr=qrcode(0,$('qr-correction').value); qr.addData(data,'Byte'); qr.make(); const meta=draw(qr); const blob=await new Promise(res=>canvas.toBlob(res,'image/png')); if(!blob) throw Error('blob'); pngUrl=URL.createObjectURL(blob); svgUrl=URL.createObjectURL(new Blob([makeSvg(qr,meta.n,meta.margin)],{type:'image/svg+xml'})); png.href=pngUrl; svg.href=svgUrl; last=data; content.textContent=label; card.classList.remove('hidden'); setDownloads(true); setStatus('Código QR generado.');}catch(e){const m=String(e.message); setStatus(m==='long'||m.includes('overflow')?'El contenido es demasiado largo para generar este código.':m==='empty'?'Completa los datos para generar el código.':'No se ha podido generar el código QR.',true);}});
$('qr-reset').addEventListener('click',()=>{document.querySelectorAll('input,textarea').forEach(el=>{if(el.type==='checkbox')el.checked=false;else el.value='';}); type.value='url'; $('qr-correction').value='M'; $('qr-size').value='1024'; $('wifi-security').value='WPA'; $('wifi-pass').type='password'; $('toggle-pass').textContent='Mostrar contraseña'; card.classList.add('hidden'); content.textContent=''; revoke(); setDownloads(false); setStatus('Completa los datos para generar el código.'); active();});
$('toggle-pass').addEventListener('click',()=>{const p=$('wifi-pass'); const show=p.type==='password'; p.type=show?'text':'password'; $('toggle-pass').textContent=show?'Ocultar contraseña':'Mostrar contraseña';});
$('qr-copy').addEventListener('click',async()=>{if(!last)return setStatus('Completa los datos para generar el código.',true); try{if(navigator.clipboard) await navigator.clipboard.writeText(last); else throw Error('clip'); setStatus('Contenido copiado.');}catch{setStatus('No se ha podido copiar automáticamente. Selecciona el contenido mostrado.',true);}});
type.addEventListener('change',active); $('wifi-security').addEventListener('change',active); $('qr-text').addEventListener('input',()=>{$('qr-text-count').textContent=$('qr-text').value.length}); window.addEventListener('beforeunload',revoke); active(); setDownloads(false);
</script>
