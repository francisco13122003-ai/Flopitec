---
const { service } = Astro.props;
---
<article class="service-card card">
  <p class="service-card__category eyebrow">{service.category}</p>
  <h2 class="service-card__title">
    <a href={`/servicios/${service.slug}/`}>{service.title}</a>
  </h2>
  <p class="service-card__description">{service.short}</p>
  <a class="service-card__cta" href={`/servicios/${service.slug}/`}>Ver servicio →</a>
</article>
