---
const { service } = Astro.props;
const href = `/servicios/${service.slug}/`;
---
<a
  class="service-card card"
  href={href}
  aria-label={`Ver ${service.title}` }
  style={`--service-image: url('${service.image}')`}
>
  <span class="service-card__media" aria-hidden="true"></span>
  <span class="service-card__overlay" aria-hidden="true"></span>
  <span class="service-card__content">
    <span class="service-card__title">{service.title}</span>
    <span class="service-card__featured">
      {service.featured.map((item) => <span>• {item}</span>)}
    </span>
    <span class="service-card__cta">Descubrir más →</span>
  </span>
</a>
