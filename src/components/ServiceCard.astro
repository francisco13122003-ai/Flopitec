---
const { service } = Astro.props;
---
<article class="card p-6"><p class="eyebrow">{service.category}</p><h2 class="mt-3 text-xl font-black"><a href={`/servicios/${service.slug}/`}>{service.title}</a></h2><p class="mt-3 text-[var(--muted)]">{service.short}</p><a class="mt-5 inline-flex font-bold text-flopi-orange" href={`/servicios/${service.slug}/`}>Ver servicio →</a></article>
